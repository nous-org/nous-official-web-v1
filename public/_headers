# Security Headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https: blob:; font-src 'self' data: https:; connect-src 'self' https:; media-src 'self' https:; object-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self';

# Favicon specific headers
/favicon.ico
  Content-Type: image/x-icon
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/favicon*.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/apple-touch-icon*.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/android-chrome*.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Web App Manifest
/site.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=604800
  Access-Control-Allow-Origin: *

/manifest.json
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=604800
  Access-Control-Allow-Origin: *

# Browser config for Windows
/browserconfig.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=604800
  Access-Control-Allow-Origin: *

# Cache static assets for 1 year
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache other assets for 1 week
/images/*
  Cache-Control: public, max-age=604800

/fonts/*
  Cache-Control: public, max-age=604800

# Don't cache HTML but allow favicon to be cached
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Root level files (robots.txt, sitemap.xml, etc.)
/robots.txt
  Cache-Control: public, max-age=86400

/sitemap*.xml
  Cache-Control: public, max-age=86400