# Baseline security headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.turso.io https://api.resend.com https://www.googletagmanager.com https://www.google-analytics.com; media-src 'self' https:; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self'; worker-src 'self' blob:;

# Google verification files
/google*.html
  Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
  # Keep verification files directly accessible.

/googletagmanager.js
  Cache-Control: public, max-age=86400
  Access-Control-Allow-Origin: *

# Sitemap and robots.txt
/robots.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8
  # Keep crawler instructions directly accessible.

/sitemap*.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml; charset=utf-8
  Access-Control-Allow-Origin: *

# Favicon headers
/favicon.ico
  Content-Type: image/x-icon
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/favicon*.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/apple-touch-icon*.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/android-chrome*.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Web App Manifest
/site.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=604800
  Access-Control-Allow-Origin: *

/manifest.json
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=604800
  Access-Control-Allow-Origin: *

# Browser config
/browserconfig.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=604800
  Access-Control-Allow-Origin: *

# Static assets
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=604800

/fonts/*
  Cache-Control: public, max-age=604800

# HTML pages
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  # Do not set restrictive X-Robots-Tag headers here.

# JSON-LD and structured data
/*.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *
