# Security Headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self' https:; media-src 'self' https:; object-src 'none'; base-uri 'self'; form-action 'self';

# Cache static assets for 1 year
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache other assets for 1 week
/images/*
  Cache-Control: public, max-age=604800

/fonts/*
  Cache-Control: public, max-age=604800

# Don't cache HTML
/*.html
  Cache-Control: public, max-age=0, must-revalidate
