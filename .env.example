# Runtime
NODE_VERSION=22.12.0

# Application
SITE_URL=https://nous.cr
NODE_ENV=production

# Email Service (Resend)
RESEND_API_KEY="your_resend_api_key"
CONTACT_RECIPIENT_EMAIL="hello@nous.cr"
SUPPORT_EMAIL="support@nous.cr"

# Database (Turso)
TURSO_DATABASE_URL="your turso database url"
TURSO_AUTH_TOKEN="your turso auth token"
TURSO_CONTACT_URL="your contact submissions database url"
TURSO_CONTACT_TOKEN="your contact submissions database token"
TURSO_NEWSLETTER_URL="your newsletter database url"
TURSO_NEWSLETTER_TOKEN="your newsletter database token"

# Blog author profile lookup (optional)
CLERK_SECRET_KEY=""

# OpenAI website chatbot
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_CHATBOT_ENABLED=true
OPENAI_CHATBOT_STORE_RESPONSES=true
# OPENAI_VECTOR_STORE_ID=""

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=""
# CLOUDFLARE_ANALYTICS_TOKEN=""

# Feature Flags (optional)
# ENABLE_ANALYTICS=false
# MAINTENANCE_MODE=false
