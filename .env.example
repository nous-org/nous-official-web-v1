# Runtime
NODE_VERSION=22.12.0

# Application
SITE_URL=https://nous.cr
NODE_ENV=production

# Email Service (Resend)
RESEND_API_KEY="your_resend_api_key"
CONTACT_RECIPIENT_EMAIL="hello@nous.cr"
SUPPORT_EMAIL="support@nous.cr"

# Database (Turso)
TURSO_DATABASE_URL="your turso database url"
TURSO_AUTH_TOKEN="your turso auth token"

# Clerk
CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key"
CLERK_SECRET_KEY="your_clerk_secret_key"

# Admin authorization. Configure at least one policy or admin APIs fail closed.
CLERK_ADMIN_USER_IDS="user_..."
# CLERK_ADMIN_ORG_IDS="org_..."
# CLERK_ADMIN_ORG_ROLES="org:admin,admin"
# CLERK_ADMIN_SESSION_CLAIM="metadata.role"
# CLERK_ADMIN_SESSION_CLAIM_VALUES="admin,true"

# OpenAI website chatbot
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_CHATBOT_ENABLED=true
OPENAI_CHATBOT_STORE_RESPONSES=true
# OPENAI_VECTOR_STORE_ID=""

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=""
# CLOUDFLARE_ANALYTICS_TOKEN=""

# Feature Flags (optional)
# ENABLE_ANALYTICS=false
# MAINTENANCE_MODE=false
