---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/ui-main-components/Hero.astro";
import FeaturedServices from "@/components/ui-main-components/FeaturedServices.astro";
import FeaturedProducts from "@/components/ui-main-components/FeaturedProducts.astro";
import Contact from "@/components/ui-main-components/Contact.astro";
import NousOffer from "@/components/ui-main-components/NousOffer.astro";


---

<Layout
	title="AI Transformation Partner in Costa Rica & LatAm | NOUS"
  description="NOUS helps organizations in Costa Rica and Latin America turn AI into useful systems: strategy, agents, automation, training, and AI-ready infrastructure."
	backgroundType="aurora"
	showAurora={true}
	useContainer={false}
	paddingType="zero"
	canonical="/"
	ogImage="/images/og-default.jpg"
	ogImageAlt="NOUS helps organizations build and deploy intelligence with AI strategy, agents, automation, and practical technology execution"
	tags={[
		"AI deployment",
		"AI transformation",
		"intelligence deployment",
		"AI-ready systems",
		"Latin America",
		"Costa Rica",
		"Consultoria en IA",
		"Automatización de procesos",
		"Transformación con IA",
		
	]}
	includeOrganizationSchema={true}
>
	<Hero locale="en" />
	<NousOffer locale="en" />
	<FeaturedServices locale="en" />
	<FeaturedProducts locale="en" />
	<Contact locale="en" />
</Layout>
