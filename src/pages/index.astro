---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/ui-main-components/Hero.astro";
import FeaturedServices from "@/components/ui-main-components/FeaturedServices.astro";
import FeaturedProducts from "@/components/ui-main-components/FeaturedProducts.astro";
import Contact from "@/components/ui-main-components/Contact.astro";
import NousOffer from "@/components/ui-main-components/NousOffer.astro";


---

<Layout
	title="NOUS Technologies: AI & Automation"
	backgroundType="aurora"
	showAurora={true}
	useContainer={false}
	paddingType="zero"
	canonical="/"
	ogImage="/images/og-homepage.jpg"
	ogImageAlt="NOUS Technologies - AI and Web Development Services"
	tags={[
		"AI consulting",
		"web development",
		"business automation",
		"Latin America",
		"digital transformation",
		"AI & Automation",
		"Desarrollo de software",
		"Consultoria en IA",
		"Automatización de procesos",
		"Desarrollo web",
		"Transformación digital",
		"Produtos a la medida",
		
	]}
	includeOrganizationSchema={true}
>
	<Hero />
	<NousOffer />
	<FeaturedServices />
	<FeaturedProducts />
	<Contact />
</Layout>
