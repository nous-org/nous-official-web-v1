---
export const prerender = false;
import { createDbClient } from '@/lib/db';
import { createClerkClient } from '@clerk/backend';
import { ShootingStars } from '@/components/react/ShootingStars';
import { StarsBackground } from '@/components/react/StarBackground';
import Layout from '@/layouts/Layout.astro';
import BlogCard from '@/components/ui/BlogCard.astro';
import NousLogoSvg from '@/assets/NousLogo.svg';
import FounderRoberto from '@/assets/founders/rpu.webp';
import ContentPagesHero from '@/components/ui/ContentPagesHero.astro';
import { getRuntimeEnv } from '@/lib/runtime-env';
import { staticBlogRows } from '@/lib/blog-fallbacks';
import { getBlogAuthorRole, normalizeOriginalLanguage } from '@/lib/blog-metadata';

const env = getRuntimeEnv();
let rows: any[] = [];
let blogLoadError = false;

if (env.TURSO_DATABASE_URL) {
  try {
    const db = createDbClient(env as { TURSO_DATABASE_URL: string; TURSO_AUTH_TOKEN?: string });
    const result = await db.execute(
      "SELECT id, slug, title, content, categorie, tags, authorId, createdAt, updatedAt, featured FROM posts WHERE status = 'PUBLISHED' ORDER BY createdAt DESC"
    );
    rows = result.rows as any[];
  } catch (error) {
    blogLoadError = true;
    console.error('Error loading blog posts:', error);
  }
} else {
  blogLoadError = true;
}

if (rows.length === 0) {
  rows = staticBlogRows;
}

function getAuthorAvatar(name: string, avatar?: string): string {
  if (name.toLowerCase().includes('roberto')) return FounderRoberto.src;
  return avatar || NousLogoSvg.src;
}

// Default author data
const defaultAuthor = {
  name: 'NOUS',
  avatar: NousLogoSvg.src,
  bio: 'Field notes from NOUS',
  role: ''
};

// Get unique author IDs to fetch from Clerk
const authorIds = [...new Set(
  rows
    .map((row: any) => row.authorId)
    .filter((id: string | null) => id && id !== 'admin')
)] as string[];

// Fetch all authors from Clerk in parallel
const authorsMap = new Map<string, { name: string; avatar: string; bio: string; role: string }>();

if (authorIds.length > 0) {
  try {
    if (!env.CLERK_SECRET_KEY) throw new Error('Missing Clerk secret key');
    const clerk = createClerkClient({ secretKey: env.CLERK_SECRET_KEY });
    const authorPromises = authorIds.map(async (authorId: string) => {
      try {
        const user = await clerk.users.getUser(authorId);
        const fullName = user.firstName && user.lastName
          ? `${user.firstName} ${user.lastName}`
          : user.username || user.emailAddresses[0]?.emailAddress || 'Anonymous';
        return {
          id: authorId,
          data: {
            name: fullName,
            avatar: getAuthorAvatar(fullName, user.imageUrl),
            bio: (user.publicMetadata?.bio as string) || '',
            role: getBlogAuthorRole(fullName)
          }
        };
      } catch {
        return { id: authorId, data: defaultAuthor };
      }
    });

    const authors = await Promise.all(authorPromises);
    authors.forEach(({ id, data }) => authorsMap.set(id, data));
  } catch (error) {
    console.error('Error fetching authors from Clerk:', error);
  }
}

// Transform database rows to match blog card format
const posts = rows.map((row: any) => {
  // Parse frontmatter from markdown content
  const content = row.content || '';
  const frontmatterMatch = content.match(/^---\n([\s\S]*?)\n---/);
  let frontmatter: any = {};

  if (frontmatterMatch) {
    const fm = frontmatterMatch[1];
    // Simple YAML parsing
    fm.split('\n').forEach((line: string) => {
      const match = line.match(/^(\w+):\s*(.+)$/);
      if (match) {
        const [, key, value] = match;
        if (value === 'true') frontmatter[key] = true;
        else if (value === 'false') frontmatter[key] = false;
        else frontmatter[key] = value.replace(/^"(.*)"$/, '$1');
      }
    });
  }

  // Extract body content (remove frontmatter)
  const bodyMatch = content.match(/^---\n[\s\S]*?\n---\n([\s\S]*)$/);
  const bodyContent = bodyMatch ? bodyMatch[1].trim() : content;

  // Get author data from Clerk or use default
  const authorData = row.author
    ? {
        ...row.author,
        avatar: getAuthorAvatar(row.author.name, row.author.avatar),
        role: getBlogAuthorRole(row.author.name, row.author.role || ''),
      }
    : row.authorId && row.authorId !== 'admin'
      ? authorsMap.get(row.authorId) || defaultAuthor
      : defaultAuthor;

  return {
    slug: row.slug,
    body: bodyContent,
    data: {
      title: row.title,
      date: new Date(row.createdAt),
      excerpt: frontmatter.excerpt || row.excerpt || '',
      category: row.categorie,
      originalLanguage: normalizeOriginalLanguage(frontmatter.originalLanguage || row.originalLanguage),
      tags: JSON.parse(row.tags || '[]'),
      featured: row.featured === true || row.featured === 1,
      author: authorData,
      draft: false
    }
  };
});

const featuredPosts = posts.filter(post => post.data.featured);
const regularPosts = posts.filter(post => !post.data.featured);
const listingPosts = featuredPosts.length > 0 ? regularPosts : posts;

---

  <Layout
    title="Blog / NOUS"
    description="Field notes from NOUS on AI transformation, abundant intelligence, automation, systems, and the technology decisions shaping organizations."
    canonical="/blog"
    backgroundType="primary"
    showAurora={false}
    useContainer={false}
  >
       <ContentPagesHero
         title="Blog"
         subtitle="Field notes on the age of abundant intelligence."
         text="Essays, observations, and practical thinking from NOUS on AI transformation, deployment, systems, and the work of building a more intelligent world."
       />

       <section class="mx-auto max-w-7xl px-4 pb-24">
         {featuredPosts.length > 0 && (
           <section class="mb-16" aria-labelledby="featured-posts-heading">
             <div class="mb-8 flex items-end justify-between gap-4 border-b border-outline/15 pb-4">
               <div>
                 <p class="text-xs font-medium uppercase tracking-[0.18em] text-outline">Selected thinking</p>
                 <h2 id="featured-posts-heading" class="mt-2 text-2xl font-medium tracking-normal text-white sm:text-3xl">
                   Featured Articles
                 </h2>
               </div>
             </div>
             <div class="grid grid-cols-1 gap-6 sm:gap-8 lg:grid-cols-2">
               {featuredPosts.map((post) => (
                 <BlogCard post={post} featured={true} locale="en" />
               ))}
             </div>
           </section>
         )}

         {listingPosts.length > 0 && (
           <section aria-labelledby="latest-posts-heading">
             <div class="mb-8 flex items-end justify-between gap-4 border-b border-outline/15 pb-4">
               <div>
                 <p class="text-xs font-medium uppercase tracking-[0.18em] text-outline">All notes</p>
                 <h2 id="latest-posts-heading" class="mt-2 text-2xl font-medium tracking-normal text-white sm:text-3xl">
                   Latest Articles
                 </h2>
               </div>
             </div>
             <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3">
               {listingPosts.map((post) => (
                 <BlogCard post={post} featured={false} locale="en" />
               ))}
             </div>
           </section>
         )}

         {posts.length === 0 && (
           <div class="rounded-[2rem] border border-outline/15 bg-white/[0.025] p-8 text-center backdrop-blur">
             <h2 class="text-2xl font-medium text-white">{blogLoadError ? 'Blog is temporarily unavailable.' : 'No articles published yet.'}</h2>
             <p class="mx-auto mt-3 max-w-2xl text-base leading-relaxed text-neutral-400">
               {blogLoadError ? 'We could not load the published articles right now. Please try again later.' : 'Field notes from NOUS will appear here once they are published.'}
             </p>
           </div>
         )}
       </section>

         <div class="absolute inset-0 pointer-events-none overflow-hidden z-[-1]">
          <div class="absolute inset-0 [mask-image:radial-gradient(ellipse_at_center_10%,black_20%,transparent_70%)] opacity-60">
              <ShootingStars client:only="react"
              minDelay={1000}
              maxDelay={1500}
              starColor="#DCD4FF"
              starHeight={2}
              starWidth={20}
             />
              <StarsBackground client:only="react" />
          </div>
        </div>

</Layout>
