---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

const posts = await getCollection(
  'blog',
  ({ data }) => !data.draft            
);
---
<Layout
    title="Blog - Nous Technologies"
    backgroundType="primary"
    useContainer={true}
    showAurora={false}
    paddingType="normal"
    canonical="/blog"
    ogImage="/images/og-blog.jpg"
    tags={['AI blog', 'technology articles', 'web development tutorials', 'business automation', 'tech insights']}
    includeOrganizationSchema={false}
>
<section class="container max-w-7xl mx-auto px-4 py-24 sm:py-28 lg:py-32">
  <header class="mb-10 sm:mb-12 lg:mb-16 text-center">
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-primary-turquoise">
      Insights & Articles
    </h1>
    <p class="mt-3 sm:mt-4 text-base sm:text-lg text-primary-purple/80">
      Latest thinking from Nous Technologies
    </p>
  </header>

  <ul role="list" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 sm:gap-8 lg:gap-10">
    {posts.map((post) => (
      <li>
        <article class="group h-full rounded-xl border border-primary-purple/20 bg-primary-black/30 backdrop-blur-sm p-5 sm:p-6 lg:p-7 transition-all duration-300 hover:-translate-y-1 hover:border-primary-turquoise/50 hover:shadow-lg hover:shadow-primary-turquoise/10 focus-within:ring-2 focus-within:ring-primary-turquoise">
          <header class="mb-4 sm:mb-5">
            <time class="block text-sm text-primary-purple/70" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString()}
            </time>
            <h3 class="mt-2 text-xl sm:text-2xl font-semibold leading-snug text-primary-turquoise group-hover:text-primary-turquoise">
              <a href={`/blog/${post.slug}/`} class="inline-flex items-baseline gap-2 outline-none focus-visible:ring-2 focus-visible:ring-primary-turquoise rounded">
                <span>{post.data.title}</span>
                <span aria-hidden class="transition-transform duration-300 group-hover:translate-x-1">→</span>
              </a>
            </h3>
          </header>

          {post.data.description && (
            <p class="text-sm sm:text-base text-primary-purple/80">
              {post.data.description}
            </p>
          )}

          {post.data.tags && post.data.tags.length > 0 && (
            <ul aria-label="Tags" class="mt-5 flex flex-wrap gap-2">
              {post.data.tags.slice(0, 4).map((tag) => (
                <li>
                  <span class="inline-flex items-center rounded-full border border-primary-purple/30 bg-primary-blue/40 px-2.5 py-1 text-xs font-medium text-primary-turquoise">
                    #{tag}
                  </span>
                </li>
              ))}
            </ul>
          )}

          <footer class="mt-6">
            <a href={`/blog/${post.slug}/`} class="inline-flex items-center gap-2 text-sm font-medium text-primary-turquoise hover:text-primary-turquoise/90 focus-visible:ring-2 focus-visible:ring-primary-turquoise rounded">
              Read article
              <span aria-hidden class="transition-transform duration-300 group-hover:translate-x-1">→</span>
            </a>
          </footer>
        </article>
      </li>
    ))}
  </ul>
</section>
</Layout>