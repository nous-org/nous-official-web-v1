---
export const prerender = false;
import { createDbClient } from '@/lib/db';
import { createClerkClient } from '@clerk/backend';
import { ShootingStars } from '@/components/react/ShootingStars';
import { StarsBackground } from '@/components/react/StarBackground';
import Layout from '@/layouts/Layout.astro';
import BlogCard from '@/components/ui/BlogCard.astro';
import NousLogoSvg from '@/assets/NousLogo.svg';

const { runtime } = Astro.locals;
const db = createDbClient(runtime.env as { TURSO_DATABASE_URL: string; TURSO_AUTH_TOKEN?: string });

// Query published posts from Turso database (including authorId)
const result = await db.execute(
  "SELECT id, slug, title, content, categorie, tags, authorId, createdAt, updatedAt FROM posts WHERE status = 'PUBLISHED' ORDER BY createdAt DESC"
);

// Helper function to get role based on name
function getAuthorRole(name: string): string {
  const lowerName = name.toLowerCase();
  if (lowerName.includes('alessandro')) return 'Chief Technology Officer (CTO)';
  if (lowerName.includes('roberto')) return 'Chief Executive Officer (CEO)';
  if (lowerName.includes('andrey')) return 'Chief Product Officer (CPO)';
  return '';
}

// Default author data
const defaultAuthor = { 
  name: 'NOUS', 
  avatar: NousLogoSvg.src, 
  bio: 'Experts in web development and AI solutions',
  role: ''
};

// Get unique author IDs to fetch from Clerk
const authorIds = [...new Set(
  result.rows
    .map((row: any) => row.authorId)
    .filter((id: string | null) => id && id !== 'admin')
)] as string[];

// Fetch all authors from Clerk in parallel
const authorsMap = new Map<string, { name: string; avatar: string; bio: string; role: string }>();

if (authorIds.length > 0) {
  try {
    const clerk = createClerkClient({ secretKey: runtime.env.CLERK_SECRET_KEY as string });
    const authorPromises = authorIds.map(async (authorId: string) => {
      try {
        const user = await clerk.users.getUser(authorId);
        const fullName = user.firstName && user.lastName 
          ? `${user.firstName} ${user.lastName}` 
          : user.username || user.emailAddresses[0]?.emailAddress || 'Anonymous';
        return {
          id: authorId,
          data: {
            name: fullName,
            avatar: user.imageUrl || NousLogoSvg.src,
            bio: (user.publicMetadata?.bio as string) || '',
            role: getAuthorRole(fullName)
          }
        };
      } catch {
        return { id: authorId, data: defaultAuthor };
      }
    });
    
    const authors = await Promise.all(authorPromises);
    authors.forEach(({ id, data }) => authorsMap.set(id, data));
  } catch (error) {
    console.error('Error fetching authors from Clerk:', error);
  }
}

// Transform database rows to match blog card format
const posts = result.rows.map((row: any) => {
  // Parse frontmatter from markdown content
  const content = row.content || '';
  const frontmatterMatch = content.match(/^---\n([\s\S]*?)\n---/);
  let frontmatter: any = {};
  
  if (frontmatterMatch) {
    const fm = frontmatterMatch[1];
    // Simple YAML parsing
    fm.split('\n').forEach(line => {
      const match = line.match(/^(\w+):\s*(.+)$/);
      if (match) {
        const [, key, value] = match;
        if (value === 'true') frontmatter[key] = true;
        else if (value === 'false') frontmatter[key] = false;
        else frontmatter[key] = value.replace(/^"(.*)"$/, '$1');
      }
    });
  }

  // Extract body content (remove frontmatter)
  const bodyMatch = content.match(/^---\n[\s\S]*?\n---\n([\s\S]*)$/);
  const bodyContent = bodyMatch ? bodyMatch[1].trim() : content;

  // Get author data from Clerk or use default
  const authorData = row.authorId && row.authorId !== 'admin' 
    ? authorsMap.get(row.authorId) || defaultAuthor
    : defaultAuthor;

  return {
    slug: row.slug,
    body: bodyContent,
    data: {
      title: row.title,
      date: new Date(row.createdAt),
      excerpt: frontmatter.excerpt || '',
      category: row.categorie,
      tags: JSON.parse(row.tags || '[]'),
      featured: frontmatter.featured === true,
      author: authorData,
      draft: false
    }
  };
});

const featuredPosts = posts.filter(post => post.data.featured);
const regularPosts = posts.filter(post => !post.data.featured);

---
  
  <Layout title="NOUS Blog" backgroundType="primary" showAurora={false} useContainer={true}>
       <section class="mx-auto max-w-7xl px-4 py-6 pt-64 sm:pt-48">
           <h1 class="mb-6 text-5xl font-semibold tracking-tight text-neutral-100 text-center">Blog</h1>
           <h2 class="mb-6 text-4xl font-semibold tracking-tight text-accent text-center">Insights & Articles</h2>
           <p class="mb-24 text-base text-neutral-400 text-center">Sharp takes, field notes, and working playbooks on AI, web, and tech decisions—written for people who ship.</p>
         
         <!-- Posts Destacados -->
         {featuredPosts.length > 0 && (
           <div class="mb-12">
             <h3 class="mb-8 text-2xl font-semibold text-accent sm:text-3xl">
               Featured Articles
             </h3>
             <div class="grid grid-cols-1 gap-6 sm:gap-8 lg:grid-cols-2">
               {featuredPosts.map((post) => (
                 <BlogCard post={post} featured={true} />
               ))}
             </div>
           </div>
         )}

         <!-- Todos los Posts -->
         <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3">
           {posts.map((post) => (
             <BlogCard post={post} featured={post.data.featured} />
           ))}
         </div>
         </section>

         <div class="absolute inset-0 pointer-events-none overflow-hidden z-[-1]">
          <div class="absolute inset-0 [mask-image:radial-gradient(ellipse_at_center_10%,black_20%,transparent_70%)] opacity-60">
              <ShootingStars client:load 
              minDelay={1000}
              maxDelay={1500}
              starColor="#1AD6B3"
              starHeight={2}
              starWidth={20}
             />
              <StarsBackground client:load />
          </div>
        </div>
      
</Layout>