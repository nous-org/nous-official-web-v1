---
export const prerender = false;
import { createDbClient } from '@/lib/db';
import Layout from '@/layouts/Layout.astro';
import { ShootingStars } from '@/components/react/ShootingStars';
import { StarsBackground } from '@/components/react/StarBackground';
import NousLogoSvg from '@/assets/NousLogo.svg';
import FounderRoberto from '@/assets/founders/rpu.webp';
import BlogContentRenderer from '@/components/ui/BlogContentRenderer.astro';
import { createClerkClient } from '@clerk/backend';
import { getRuntimeEnv } from '@/lib/runtime-env';
import { getStaticBlogRow } from '@/lib/blog-fallbacks';

const { slug } = Astro.params;

if (!slug) {
  return new Response('Not found', { status: 404 });
}

const env = getRuntimeEnv();
let row: any | undefined;

if (!env.TURSO_DATABASE_URL) {
  row = getStaticBlogRow(slug);
} else {
  try {
    const db = createDbClient(env as { TURSO_DATABASE_URL: string; TURSO_AUTH_TOKEN?: string });
    const result = await db.execute(
      "SELECT id, slug, title, content, categorie, tags, authorId, createdAt, updatedAt, featured FROM posts WHERE slug = ? AND status = 'PUBLISHED'",
      [slug]
    );

    row = (result.rows[0] as any | undefined) || getStaticBlogRow(slug);
  } catch (error) {
    console.error('Error loading blog article:', error instanceof Error ? error.message : 'Unknown error');
    row = getStaticBlogRow(slug);
  }
}

if (!row) {
  return new Response('Not found', { status: 404 });
}

const markdownContent = row.content || '';

// Parse frontmatter
const frontmatterMatch = markdownContent.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
let frontmatter: any = {};
let bodyContent = markdownContent;

if (frontmatterMatch) {
  const [, fm, body] = frontmatterMatch;
  bodyContent = body;

  // Parse YAML frontmatter
  const lines = fm.split('\n');
  let inAuthor = false;

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;

    if (trimmed === 'author:') {
      inAuthor = true;
      frontmatter.author = {};
      continue;
    }

    if (inAuthor && trimmed.startsWith('  ')) {
      const [key, ...valueParts] = trimmed.substring(2).split(':');
      const value = valueParts.join(':').trim().replace(/^"(.*)"$/, '$1');
      frontmatter.author[key.trim()] = value;
      continue;
    } else if (inAuthor) {
      inAuthor = false;
    }

    if (trimmed.includes(':')) {
      const [key, ...valueParts] = trimmed.split(':');
      const value = valueParts.join(':').trim();

      if (value === 'true' || value === 'false') {
        frontmatter[key] = value === 'true';
      } else {
        frontmatter[key] = value.replace(/^"(.*)"$/, '$1');
      }
    }
  }
}

// Helper function to get role based on name
function getAuthorRole(name: string): string {
  const lowerName = name.toLowerCase();
  if (lowerName.includes('alessandro')) return 'Chief Technology Officer (CTO)';
  if (lowerName.includes('roberto')) return 'Chief Executive Officer (CEO)';
  if (lowerName.includes('andrey')) return 'Chief Product Officer (CPO)';
  return '';
}

function getAuthorAvatar(name: string, avatar?: string): string {
  if (name.toLowerCase().includes('roberto')) return FounderRoberto.src;
  return avatar || NousLogoSvg.src;
}

let authorData = {
  name: row.author?.name || 'NOUS',
  avatar: getAuthorAvatar(row.author?.name || 'NOUS', row.author?.avatar),
  bio: row.author?.bio || 'Field notes from the age of abundant intelligence.',
  role: row.author?.role || '',
};

if (row.authorId && row.authorId !== 'admin') {
  try {
    if (!env.CLERK_SECRET_KEY) throw new Error('Missing Clerk secret key');
    const clerk = createClerkClient({ secretKey: env.CLERK_SECRET_KEY });
    const user = await clerk.users.getUser(row.authorId);

    const fullName = user.firstName && user.lastName ? `${user.firstName} ${user.lastName}` : user.username || user.emailAddresses[0]?.emailAddress || 'Anonymous';

    authorData = {
      name: fullName,
      avatar: getAuthorAvatar(fullName, user.imageUrl),
      bio: user.publicMetadata?.bio as string || '',
      role: getAuthorRole(fullName)
    };
  } catch (error) {
    console.error('Error fetching author from Clerk:', error);
  }
}

// Create post object
const post = {
  slug: row.slug,
  body: bodyContent,
  data: {
    title: row.title,
    date: new Date(row.createdAt),
    excerpt: frontmatter.excerpt || row.excerpt || '',
    category: row.categorie,
    tags: JSON.parse(row.tags || '[]'),
    featured: row.featured === true || row.featured === 1,
    author: authorData,
    draft: false
  }
};

// Función para calcular tiempo de lectura
function calculateReadingTime(content: string): number {
  const wordsPerMinute = 200;
  const words = content.trim().split(/\s+/).length;
  return Math.ceil(words / wordsPerMinute);
}

function escapeRegExp(value: string): string {
  return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function stripLeadingDuplicateTitle(content: string, title: string): string {
  const titlePattern = escapeRegExp(title.trim());
  const duplicateTitlePattern = new RegExp(`^\\s{0,3}#{1,6}\\s+${titlePattern}\\s*(?:\\r?\\n)+`, 'i');

  return content.replace(duplicateTitlePattern, '').trimStart();
}

const articleBodyContent = stripLeadingDuplicateTitle(bodyContent, post.data.title);
const readingTime = calculateReadingTime(articleBodyContent);

// Formatear fecha
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
};
---

<Layout
  title={`${post.data.title} / NOUS`}
  description={post.data.excerpt}
  canonical={`/blog/${post.slug}`}
  backgroundType="primary"
  showAurora={false}
  useContainer={false}
>
  <a id="top" class="sr-only" aria-hidden="true"></a>

  <header class="mx-auto max-w-5xl px-4 pb-12 pt-36 sm:pb-16 sm:pt-44">
    <article class="relative isolate overflow-hidden rounded-[2rem] border border-outline/15 bg-white/[0.025] p-6 shadow-[0_24px_80px_rgba(0,0,0,0.24)] backdrop-blur sm:p-10 lg:p-12">
      <div class="pointer-events-none absolute inset-x-8 top-0 h-px bg-gradient-to-r from-transparent via-outline/60 to-transparent" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(220,212,255,0.16),transparent_42%)]" aria-hidden="true"></div>

      <div class="relative z-10">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex flex-wrap items-center gap-2 text-sm text-neutral-400">
            <li>
              <a href="/" class="transition-colors hover:text-outline focus:outline-none focus-visible:ring-2 focus-visible:ring-outline/50 rounded">
                Home
              </a>
            </li>
            <li aria-hidden="true" class="text-neutral-600">/</li>
            <li>
              <a href="/blog" class="transition-colors hover:text-outline focus:outline-none focus-visible:ring-2 focus-visible:ring-outline/50 rounded">
                Blog
              </a>
            </li>
          </ol>
        </nav>

        <a
          href="/blog"
          class="mb-6 inline-flex min-h-10 items-center gap-2 rounded-full border border-outline/25 bg-white/[0.03] px-4 py-2 text-sm font-medium text-outline transition-colors hover:border-outline/60 hover:bg-outline/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline/40"
        >
          <span aria-hidden="true">←</span>
          <span>Back to blog</span>
        </a>

        <div class="mb-6 flex flex-wrap items-center gap-2 text-sm text-neutral-300">
          <time datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
          <span aria-hidden="true" class="h-1 w-1 rounded-full bg-outline/60"></span>
          <span>
            {readingTime} min read
          </span>
          {post.data.category && (
            <>
              <span aria-hidden="true" class="h-1 w-1 rounded-full bg-outline/60"></span>
              <span class="text-outline">
                {post.data.category}
              </span>
            </>
          )}
        </div>

        <h1 class="max-w-4xl bg-gradient-to-r from-gradient-start via-gradient-middle to-gradient-end bg-clip-text text-3xl font-medium leading-[1.08] tracking-normal text-transparent sm:text-4xl lg:text-5xl">
          {post.data.title}
        </h1>

        {post.data.excerpt && (
          <p class="mt-6 max-w-4xl text-base leading-relaxed text-neutral-300 sm:text-justify sm:text-lg">
            {post.data.excerpt}
          </p>
        )}

        <div class="mt-8 flex flex-col gap-5 border-t border-outline/15 pt-6 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-center gap-3">
            <img
              src={post.data.author.avatar || NousLogoSvg.src}
              alt={`Avatar of ${post.data.author.name}`}
              class="h-11 w-11 rounded-full border-2 border-outline/20 object-cover"
              loading="lazy"
              decoding="async"
            />
            <div>
              <p class="font-medium text-neutral-100">{post.data.author.name}</p>
              {post.data.author.role && (
                <p class="text-sm font-medium text-outline">{post.data.author.role}</p>
              )}
              {post.data.author.bio && (
                <p class="text-sm text-neutral-400">{post.data.author.bio}</p>
              )}
            </div>
          </div>

          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap items-center gap-2 sm:self-center sm:justify-end">
              {post.data.tags.map((tag: string) => (
                <span class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.035] px-3 py-1 text-xs font-medium text-neutral-300">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </article>
  </header>

  <section aria-label="Article body" class="mx-auto max-w-5xl px-4 pb-16 sm:pb-24">
    <article class="article-prose rounded-[2rem] border border-outline/10 bg-white/[0.018] p-6 text-neutral-300 backdrop-blur sm:p-10 lg:p-12">
      <BlogContentRenderer content={articleBodyContent} />
    </article>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-24">
    <div class="rounded-[2rem] border border-outline/15 bg-white/[0.025] p-6 text-center shadow-[0_24px_80px_rgba(0,0,0,0.18)] backdrop-blur sm:p-10">
      <p class="text-sm font-medium uppercase tracking-[0.18em] text-outline">NOUS field notes</p>
      <h2 class="mx-auto mt-3 max-w-4xl text-2xl font-medium leading-tight text-white sm:text-3xl">
        Thinking through the age of abundant intelligence.
      </h2>
      <p class="mx-auto mt-4 max-w-4xl text-base leading-relaxed text-neutral-300">
        Read more essays from NOUS or start a conversation about how these ideas apply inside your organization.
      </p>
      <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/blog" class="inline-flex min-h-11 items-center justify-center rounded-full border border-transparent bg-outline px-5 py-2.5 text-sm font-medium text-primary-black transition-colors hover:bg-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-outline/60">
          Back to blog
        </a>
        <a href="/contact" class="inline-flex min-h-11 items-center justify-center rounded-full border border-outline/45 bg-transparent px-5 py-2.5 text-sm font-medium text-outline transition-colors hover:border-outline hover:bg-outline/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline/60">
          Talk to NOUS
        </a>
      </div>
    </div>
  </section>

  <!-- Scroll to top floating button -->
  <button
    id="scrollTopBtn"
    type="button"
    aria-label="Back to top"
    class="fixed bottom-6 right-6 z-40 inline-flex h-11 w-11 items-center justify-center rounded-full border border-outline/25 bg-primary-black/70 text-outline opacity-0 shadow-lg backdrop-blur transition-all hover:scale-105 hover:border-outline/60 hover:bg-outline/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline/60 pointer-events-none"
  >
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24"><path fill="currentColor" d="m11 7.825l-4.9 4.9q-.3.3-.7.288t-.7-.313q-.275-.3-.288-.7t.288-.7l6.6-6.6q.15-.15.325-.212T12 4.425t.375.063t.325.212l6.6 6.6q.275.275.275.688t-.275.712q-.3.3-.712.3t-.713-.3L13 7.825V19q0 .425-.288.713T12 20t-.712-.288T11 19z"/></svg>
  </button>

  <div class="absolute inset-0 pointer-events-none overflow-hidden z-[-1]">
    <div class="absolute inset-0 [mask-image:radial-gradient(ellipse_at_center_10%,black_20%,transparent_70%)] opacity-60">
        <ShootingStars client:only="react"
        minDelay={1000}
        maxDelay={1500}
        starColor="#DCD4FF"
        starHeight={2}
        starWidth={20}
       />
        <StarsBackground client:only="react" />
    </div>
  </div>
</Layout>
<script is:inline>

  (function () {
    'use strict';

    let scrollBtn = null;
    let isVisible = false;
    let ticking = false;
    let cleanup = null;

    const SCROLL_THRESHOLD = 240;
    const TRANSITION_CLASSES = {
      show: ['opacity-0', 'pointer-events-none'],
      hide: ['opacity-0', 'pointer-events-none']
    };

    const handleScroll = () => {
      if (ticking || !scrollBtn) return;

      ticking = true;
      requestAnimationFrame(() => {
        const shouldShow = window.scrollY > SCROLL_THRESHOLD;


        if (shouldShow !== isVisible) {
          isVisible = shouldShow;

          if (isVisible) {
            scrollBtn.classList.remove(...TRANSITION_CLASSES.show);
          } else {
            scrollBtn.classList.add(...TRANSITION_CLASSES.hide);
          }
        }

        ticking = false;
      });
    };

    const handleClick = (e) => {
      e.preventDefault();

      if ('scrollBehavior' in document.documentElement.style) {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      } else {
        window.scrollTo(0, 0);
      }
    };
    const init = () => {
      if (cleanup) cleanup();

        scrollBtn = document.getElementById('scrollTopBtn');
      if (!scrollBtn) {
        console.warn('Scroll button with ID "scrollTopBtn" not found');
        return;
      }

      isVisible = false;
      ticking = false;

      window.addEventListener('scroll', handleScroll, {
        passive: true,
        capture: false
      });
      scrollBtn.addEventListener('click', handleClick, { passive: false });

      handleScroll();

      cleanup = () => {
        if (scrollBtn) {
          window.removeEventListener('scroll', handleScroll);
          scrollBtn.removeEventListener('click', handleClick);
        }
        scrollBtn = null;
        isVisible = false;
        ticking = false;
      };
    };

    const handlePageLoad = () => {
      requestAnimationFrame(() => {
        init();
      });
    };

    const handleBeforeSwap = () => {
      if (cleanup) {
        cleanup();
        cleanup = null;
      }
    };

    document.addEventListener('astro:page-load', handlePageLoad);
    document.addEventListener('astro:before-swap', handleBeforeSwap);

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', handlePageLoad);
    } else {
      handlePageLoad();
    }

    window.addEventListener('beforeunload', handleBeforeSwap);
  })();
</script>

<style is:global>
  article.article-prose code {
    color: #dcd4ff;
    background-color: rgba(220, 212, 255, 0.08);
    border: 1px solid rgba(220, 212, 255, 0.12);
    padding: 0.125rem 0.3rem;
    border-radius: 0.35rem;
    font-size: 0.875em;
  }

  article.article-prose pre {
    background-color: rgba(4, 0, 15, 0.82);
    border: 1px solid rgba(220, 212, 255, 0.14);
    border-radius: 0.75rem;
    padding: 1rem;
    overflow-x: auto;
  }

  article.article-prose pre code {
    background-color: transparent;
    border: 0;
    padding: 0;
  }

  article.article-prose img {
    border-radius: 0.75rem;
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.32);
    margin: 2rem 0;
  }
</style>
