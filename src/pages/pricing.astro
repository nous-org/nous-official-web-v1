---
import Layout from "@/layouts/Layout.astro";
import ContentPagesHero from "@/components/ui/ContentPagesHero.astro";
import PricingCards from "@/components/ui/PricingCards.astro";
import type { Button } from "@/types/callToAction";
import SubscribeToNewsletter from "@/components/ui/SubscribeToNewsLetter.astro";
import Contact from "@/components/ui-main-components/Contact.astro";
import FrequentlyQuestions from "@/components/ui/FrequentlyQuestions.astro";
import BreadcrumbSchema from "@/components/seo/BreadCrumbs.astro";
import ServiceSchema from "@/components/seo/ServicesSchema.astro";

export const prerender = false;
interface Hero {
    title: string;
    subtitle: string;
    buttons: Button[];
}
const HERO: Hero = {
    title: "So what does it cost?",
    subtitle:
        "Smart AI automation tools, consulting, and web development tailored to your needs.",
    buttons: [
        {
            text: "Contact",
            variant: "secondary",
            href: "/contact",
            scheduleIcon: false,
            strokeColor: "#060114",
            arrowIcon: true,
            target: "_self",
            ariaLabel: "Contact",
        },
        {
            text: "Schedule",
            variant: "secondaryTurquoise",
            href: "/contact",
            scheduleIcon: true,
            strokeColor: "#1AD6B3",
            arrowIcon: false,
            target: "_self",
            ariaLabel: "Request a demo",
        },
    ],
};
const { title, subtitle, buttons } = HERO;

const breadcrumbs = [
    { name: "Home", url: "/" },
    { name: "Pricing", url: "/pricing" },
];

const pricingSchema = {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "Nous Technologies Services",
    description:
        "AI consulting, web development, and business automation services",
    brand: {
        "@type": "Brand",
        name: "Nous Technologies",
    },
    offers: [
        {
            "@type": "Offer",
            name: "AI-Powered Automation",
            description:
                "Perfect for small businesses starting their digital transformation",
            price: "600",
            priceCurrency: "USD",
            availability: "https://schema.org/InStock",
            validFrom: "2025-01-01",
            priceValidUntil: "2025-12-31",
            itemCondition: "https://schema.org/NewCondition",
        },
        {
            "@type": "Offer",
            name: "Custom Web Development",
            description:
                "Custom web development solutions for growing businesses",
            price: "500",
            priceCurrency: "USD",
            availability: "https://schema.org/InStock",
            validFrom: "2025-01-01",
            priceValidUntil: "2025-12-31",
            itemCondition: "https://schema.org/NewCondition",
        },
        {
            "@type": "Offer",
            name: "AI Consulting",
            description:
                "Custom AI solutions and enterprise-grade web applications",
            price: "1000",
            priceCurrency: "USD",
            availability: "https://schema.org/InStock",
            validFrom: "2025-01-01",
            priceValidUntil: "2025-12-31",
            itemCondition: "https://schema.org/NewCondition",
        },
    ],
};
---

<Layout
    title="Pricing - Nous Technologies"
    backgroundType="primary"
    useContainer={true}
    showAurora={false}
    paddingType="normal"
    canonical="/pricing"
    ogImage="/images/og-pricing.jpg"
    ogImageAlt="Nous Technologies Pricing Plans - AI Consulting and Web Development Services"
    tags={[
        "pricing",
        "AI consulting costs",
        "web development pricing",
        "business automation packages",
        "technology services rates",
    ]}
    customSchema={pricingSchema}
    includeOrganizationSchema={false}
>
    <BreadcrumbSchema items={breadcrumbs} />
    <ServiceSchema
        serviceName="AI Consulting & Strategy"
        description="Strategic AI implementation consulting to help businesses leverage artificial intelligence for competitive advantage"
        category="Technology Consulting"
        price="600"
    />

    <ServiceSchema
        serviceName="Custom Web Development"
        description="Bespoke web application development using modern technologies and best practices"
        category="Software Development"
        price="500"
    />

    <ServiceSchema
        serviceName="Business Process Automation"
        description="Automate repetitive tasks and optimize workflows using AI and custom software solutions"
        category="Business Automation"
        price="1000"
    />
    <ContentPagesHero title={title} subtitle={subtitle} buttons={buttons} />

    <PricingCards />

    <FrequentlyQuestions />

    <SubscribeToNewsletter />

    <Contact />
</Layout>
