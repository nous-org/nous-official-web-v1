---
import Layout from '@/layouts/Layout.astro';
import ContentPagesHero from '@/components/ui/ContentPagesHero.astro';
import AboutBento from '@/components/ui/AboutBento.astro';
import FoundersSection from '@/components/ui/FoundersSection.astro';
import ContactCta from '@/components/ui/ContactCta.astro';
import MainCta from '@/components/ui/MainCta.astro';
import BreadcrumbSchema from '@/components/seo/BreadCrumbs.astro';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about-us' }
];

---

<Layout 
    title="About NOUS"
    backgroundType="primary"
    useContainer={true}
    showAurora={false}
    paddingType="normal"
    canonical="/about-us"
    ogImage="/images/og-default.jpg"
    tags={[
        'about us', 
        'company', 
        'team', 
        'mission', 
        'AI experts',
        'acerca de nosotros',
        'empresa',
        'equipo',
        'misión',
        'expertos en IA',
        'quiénes somos',
        'nuestra historia',
        'equipo técnico',
        'especialistas en IA',
        'fundadores',
    ]}
    includeOrganizationSchema={false}
>
    <BreadcrumbSchema items={breadcrumbs} />
    <ContentPagesHero subtitle='Build what’s next, beautifully.' text='A senior, hands-on team from Costa Rica for what moves the needle now—AI automation to free time or modern web development to win customers, delivered calmly and fast.'/>
    <AboutBento />
    <FoundersSection />
    <MainCta />

    <ContactCta />
</Layout>
