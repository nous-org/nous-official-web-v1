---
import SectionContact from "@/components/ui-main-components/ContactPage.astro";
import Layout from "@/layouts/Layout.astro";
import BreadcrumbSchema from "@/components/seo/BreadCrumbs.astro";

export const prerender = false;

const breadcrumbs = [
    { name: "Inicio", url: "/es/" },
    { name: "Contacto", url: "/es/contact" },
];

const contactSchema = {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    mainEntity: {
        "@type": "Organization",
        name: "NOUS",
        contactPoint: {
            "@type": "ContactPoint",
            telephone: "+506-6186-5634",
            contactType: "customer service",
            email: "hello@nous.cr",
            availableLanguage: ["English", "Spanish"],
        },
    },
};
---

<Layout
    title="Habla con NOUS sobre Estrategia y Despliegue de IA"
    description="Cuéntanos dónde la IA podría crear ventaja en tu organización. Ayudamos a equipos a priorizar, construir y desplegar sistemas útiles con IA."
    backgroundType="primary"
    showAurora={false}
    useContainer={false}
    paddingType="zero"
    canonical="/es/contact"
    ogImage="/images/og-default.jpg"
    tags={[
        "contacto",
        "consulta",
        "despliegue de IA",
        "transformación con IA",
        "despliegue de inteligencia",
        "consultoría",
        "consultoría en IA",
        "asesoría técnica",
    ]}
    customSchema={contactSchema}
    includeOrganizationSchema={false}
    locale="es"
>
    <BreadcrumbSchema items={breadcrumbs} />
    <SectionContact locale="es" />
</Layout>
