---
import Layout from "@/layouts/Layout.astro";
import ContentPagesHero from "@/components/ui/ContentPagesHero.astro";
import type { Button } from "@/types/callToAction";
import CarouselContainer from "@/components/ui/CarouselContainer.astro";
import { StickyServices } from "@/components/react/StickyServices";
import { RippleCta } from "@/components/react/RippleCta";
import SubscribeToNewsletter from "@/components/ui/SubscribeToNewsLetter.astro";
import Contact from "@/components/ui-main-components/Contact.astro";
import BreadcrumbSchema from "@/components/seo/BreadCrumbs.astro";
import ServiceSchema from "@/components/seo/ServicesSchema.astro";

export const prerender = false;
interface Hero {
    title: string;
    subtitle: string;
    buttons: Button[];
}

const HERO: Hero = {
    title: "Products",
    subtitle: "AI automation, custom web development, and technology consulting to boost your digital products",
    buttons: [
        {
            text: "Contact",
            variant: "secondary",
            href: "/contact",
            scheduleIcon: false,
            strokeColor: "#060114",
            arrowIcon: true,
            target: "_self",
            ariaLabel: "Contact",
        },
        {
            text: "Schedule",
            variant: "secondaryTurquoise",
            href: "/contact",
            scheduleIcon: true,
            strokeColor: "#1AD6B3",
            arrowIcon: false,
            target: "_self",
            ariaLabel: "Request a demo",
        },
    ],
};

const { title, subtitle, buttons } = HERO;

// Breadcrumbs para SEO
const breadcrumbs = [
    { name: 'Home', url: '/' },
    { name: 'Products', url: '/products' }
];

// Schema para productos/servicios específicos
const productsSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Nous Technologies Products & Services",
    "description": "Comprehensive AI automation, web development, and technology consulting products",
    "numberOfItems": 6,
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "item": {
                "@type": "Product",
                "name": "AI Chatbot Integration",
                "description": "Intelligent chatbots that automate customer service and lead generation with 24/7 availability",
                "category": "AI Automation",
                "brand": {
                    "@type": "Brand",
                    "name": "Nous Technologies"
                },
                "offers": {
                    "@type": "Offer",
                    "price": "299",
                    "priceCurrency": "USD",
                    "availability": "https://schema.org/InStock"
                }
            }
        },
        {
            "@type": "ListItem",
            "position": 2,
            "item": {
                "@type": "Product",
                "name": "Custom Web Applications",
                "description": "Bespoke web applications built with modern frameworks like Astro, React, and TypeScript",
                "category": "Web Development",
                "brand": {
                    "@type": "Brand",
                    "name": "Nous Technologies"
                },
                "offers": {
                    "@type": "Offer",
                    "price": "500",
                    "priceCurrency": "USD",
                    "availability": "https://schema.org/InStock"
                }
            }
        },
        {
            "@type": "ListItem",
            "position": 3,
            "item": {
                "@type": "Product",
                "name": "Business Process Automation",
                "description": "Intelligent automation solutions that streamline workflows and increase operational efficiency",
                "category": "Business Automation",
                "brand": {
                    "@type": "Brand",
                    "name": "Nous Technologies"
                },
                "offers": {
                    "@type": "Offer",
                    "price": "1000",
                    "priceCurrency": "USD",
                    "availability": "https://schema.org/InStock"
                }
            }
        },
        {
            "@type": "ListItem",
            "position": 4,
            "item": {
                "@type": "Product",
                "name": "E-commerce Solutions",
                "description": "Complete e-commerce platforms with payment integration, inventory management, and analytics",
                "category": "E-commerce Development",
                "brand": {
                    "@type": "Brand",
                    "name": "Nous Technologies"
                },
                "offers": {
                    "@type": "Offer",
                    "price": "3500",
                    "priceCurrency": "USD",
                    "availability": "https://schema.org/InStock"
                }
            }
        },
        {
            "@type": "ListItem",
            "position": 5,
            "item": {
                "@type": "Product",
                "name": "AI Strategy Consulting",
                "description": "Strategic AI implementation consulting with ROI analysis and technology roadmaps",
                "category": "Technology Consulting",
                "brand": {
                    "@type": "Brand",
                    "name": "Nous Technologies"
                },
                "offers": {
                    "@type": "Offer",
                    "price": "5000",
                    "priceCurrency": "USD",
                    "availability": "https://schema.org/InStock"
                }
            }
        },
        {
            "@type": "ListItem",
            "position": 6,
            "item": {
                "@type": "Product",
                "name": "Digital Transformation Solutions",
                "description": "End-to-end digital transformation services including cloud migration and system modernization",
                "category": "Digital Transformation",
                "brand": {
                    "@type": "Brand",
                    "name": "Nous Technologies"
                },
                "offers": {
