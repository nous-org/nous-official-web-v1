// Schema adicional para la página como catálogo de productos
const catalogSchema = {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Nous Technologies Products & Services",
    "description": "Explore our comprehensive range of AI automation, web development, and technology consulting products designed to transform your business",
    "url": "https://nous.cr/products",
    "mainEntity": {
        "@type": "ItemList",
        "name": "Product Catalog",
        "numberOfItems": 6
    },
    "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": "Home",
                "item": "https://nous.cr/"
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "Products",
                "item": "https://nous.cr/products"
            }
        ]
    }
};
---

<Layout
    title="AI Products & Digital Solutions | Nous Technologies"
    description="Discover our comprehensive range of AI automation tools, custom web applications, and technology consulting products. Transform your business with cutting-edge digital solutions designed for Latin American companies."
    canonical="/products"
    ogImage="/images/og-products.jpg"
    ogImageAlt="Nous Technologies Products - AI Automation, Web Development, and Technology Solutions"
    tags={['AI products', 'web development solutions', 'business automation tools', 'digital transformation', 'technology products', 'Latin America']}
    backgroundType="primary"
    useContainer={true}
    showAurora={false}
    paddingType="zero"
    customSchema={[productsSchema, catalogSchema]}
    includeOrganizationSchema={false}
>
    <!-- SEO Schemas -->
    <BreadcrumbSchema items={breadcrumbs} />
    
    <!-- Individual Service Schemas -->
    <ServiceSchema
        serviceName="AI Chatbot Integration"
        description="Intelligent chatbots that automate customer service, lead generation, and support with 24/7 availability and natural language processing"
        category="AI Automation"
        price="299"
        currency="USD"
    />
    
    <ServiceSchema
        serviceName="Custom Web Applications"
        description="Bespoke web applications built with modern frameworks like Astro, React, and TypeScript for optimal performance and user experience"
        category="Web Development"
        price="500"
        currency="USD"
    />
    
    <ServiceSchema
        serviceName="Business Process Automation"
        description="Intelligent automation solutions that streamline workflows, reduce manual tasks, and increase operational efficiency"
        category="Business Automation"
        price="600"
        currency="USD"
    />
    
    <ServiceSchema
        serviceName="E-commerce Solutions"
        description="Complete e-commerce platforms with payment integration, inventory management, analytics, and mobile-responsive design"
        category="E-commerce Development"
        price="500"
        currency="USD"
    />
    
    <ServiceSchema
        serviceName="AI Strategy Consulting"
        description="Strategic AI implementation consulting with ROI analysis, technology roadmaps, and change management support"
        category="Technology Consulting"
        price="500"
        currency="USD"
    />
    
    <ServiceSchema
        serviceName="Digital Transformation Solutions"
        description="End-to-end digital transformation services including cloud migration, system modernization, and process optimization"
        category="Digital Transformation"
        price="1000"
        currency="USD"
    />

    <!-- Contenido de la página -->
    <div class="px-4">
        <ContentPagesHero title={title} subtitle={subtitle} buttons={buttons} />
    </div>
    
    <CarouselContainer />
    
    <div class="mt-32 mb-32">
        <StickyServices client:load />
    </div>

    <RippleCta />
    
    <SubscribeToNewsletter />
    
    <Contact />
</Layout>