---
import type { Button } from "@/types/callToAction";
import Layout from "@/layouts/Layout.astro";
import ContentPagesHero from "@/components/ui/ContentPagesHero.astro";
import { ServicesMarquee } from "@/components/react/ServicesMarquee";
import OurServices from "@/components/ui/OurServices.astro";
import Contact from "@/components/ui-main-components/Contact.astro";
import ServicesCards from "@/components/ui/ServicesCards.astro";
import WorkProcess from "@/components/ui/WorkProcess.astro";
import ServiceSchema from "@/components/seo/ServicesSchema.astro";
import BreadcrumbSchema from "@/components/seo/BreadCrumbs.astro";
import FrequentlyQuestions from "@/components/ui/FrequentlyQuestions.astro";

export const prerrender = false;

interface Hero {
    title: string;
    subtitle: string;
    buttons: Button[];
}
const breadcrumbs = [
    { name: "Home", url: "/" },
    { name: "Services", url: "/services" },
];

const HERO: Hero = {
    title: "What Nous does?",
    subtitle:
        "We are your intelligent automation, custom web development, and AI consulting team that grows with you.",
    buttons: [
        {
            text: "Contact",
            variant: "secondary",
            href: "/contact",
            scheduleIcon: false,
            strokeColor: "#060114",
            arrowIcon: true,
            target: "_self",
            ariaLabel: "Contact",
        },
        {
            text: "Schedule",
            variant: "secondaryTurquoise",
            href: "/contact",
            scheduleIcon: true,
            strokeColor: "#1AD6B3",
            arrowIcon: false,
            target: "_self",
            ariaLabel: "Request a demo",
        },
    ],
};
const { title, subtitle, buttons } = HERO;
---

<Layout
    title="Products - Nous Technologies"
    backgroundType="primary"
    useContainer={true}
    showAurora={false}
    paddingType="zero"
    canonical="/services"
    ogImage="/images/og-default.jpg"
    tags={[
        "AI consulting",
        "web development",
        "business automation",
        "machine learning",
        "digital transformation",
    ]}
    includeOrganizationSchema={false}
>
    <BreadcrumbSchema items={breadcrumbs} />
    <ServiceSchema
    serviceName="AI Consulting & Strategy"
    description="Strategic AI implementation consulting to help businesses leverage artificial intelligence for competitive advantage"
    category="Technology Consulting"
    price="600"
  />
  
  <ServiceSchema
    serviceName="Custom Web Development"
    description="Bespoke web application development using modern technologies and best practices"
    category="Software Development"
    price="500"
  />
  
  <ServiceSchema
    serviceName="Business Process Automation"
    description="Automate repetitive tasks and optimize workflows using AI and custom software solutions"
    category="Business Automation"
    price="1000"
  />
    <div class="px-4">
        <ContentPagesHero title={title} subtitle={subtitle} buttons={buttons} />
        <OurServices />
        <ServicesCards />
        <WorkProcess />
    </div>
    <div class="px-0 md:px-4">
        <ServicesMarquee client:idle />
    </div>
    <FrequentlyQuestions />


    <Contact />
</Layout>
