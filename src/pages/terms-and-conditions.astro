---
import ContentPagesHero from "@/components/ui/ContentPagesHero.astro";
import Layout from "@/layouts/Layout.astro";
import { getCollection, render } from "astro:content";

const entries = await getCollection("termsandconditions");
const termsEntry =
  entries.find((entry: any) => entry.slug === "termsandconditions") ?? entries[0];

if (!termsEntry) {
  throw new Error("No entries found in termsandconditions collection");
}

const { Content } = await render(termsEntry);
const { data } = termsEntry;

const language = data.language || "English";
---

<Layout
  title="Terms and Conditions / NOUS"
  description={data.description}
  canonical="/terms-and-conditions"
  backgroundType="primary"
  showAurora={false}
  useContainer={false}
  includeOrganizationSchema={false}
>
  <ContentPagesHero
    title={data.title}
    subtitle={data.description}
  />

  <section class="mx-auto max-w-5xl px-4 pb-24">
    <dl class="grid gap-3 rounded-2xl border border-outline/15 bg-white/[0.025] p-4 text-sm text-neutral-300 backdrop-blur sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-white/5 bg-white/[0.02] p-4">
        <dt class="text-xs font-medium uppercase tracking-[0.16em] text-outline">Effective date</dt>
        <dd class="mt-2 text-white">{data.effectiveDate}</dd>
      </div>
      <div class="rounded-xl border border-white/5 bg-white/[0.02] p-4">
        <dt class="text-xs font-medium uppercase tracking-[0.16em] text-outline">Last updated</dt>
        <dd class="mt-2 text-white">{data.lastUpdated}</dd>
      </div>
      <div class="rounded-xl border border-white/5 bg-white/[0.02] p-4">
        <dt class="text-xs font-medium uppercase tracking-[0.16em] text-outline">Language</dt>
        <dd class="mt-2 text-white">{language}</dd>
      </div>
      <div class="rounded-xl border border-white/5 bg-white/[0.02] p-4">
        <dt class="text-xs font-medium uppercase tracking-[0.16em] text-outline">Company</dt>
        <dd class="mt-2 text-white">{data.company.name}</dd>
      </div>
    </dl>

    <article class="legal-prose mt-8 rounded-[2rem] border border-outline/15 bg-white/[0.025] p-6 shadow-[0_24px_80px_rgba(0,0,0,0.24)] backdrop-blur sm:p-10 lg:p-12">
      <Content />
    </article>

    <div class="mt-12 flex justify-center">
      <a
        href="#main-content"
        class="inline-flex min-h-11 items-center justify-center rounded-full border border-outline/25 bg-white/[0.03] px-5 py-2.5 text-sm font-medium text-outline transition-colors hover:border-outline/60 hover:bg-outline/10 focus:outline-none focus:ring-2 focus:ring-outline/40"
        aria-label="Back to top"
      >
        Back to top
      </a>
    </div>
  </section>
</Layout>

<style is:inline>
  article.legal-prose {
    color: rgba(229, 229, 229, 0.86);
  }

  article.legal-prose h2 {
    margin-top: 3rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(220, 212, 255, 0.18);
    padding-bottom: 0.75rem;
    color: #ffffff;
    font-size: clamp(1.75rem, 2.3vw, 2.4rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: 0;
  }

  article.legal-prose h2:first-child {
    margin-top: 0;
  }

  article.legal-prose h3 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #dcd4ff;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.25;
  }

  article.legal-prose p,
  article.legal-prose li {
    color: rgba(229, 229, 229, 0.78);
    font-size: 1rem;
    line-height: 1.8;
  }

  article.legal-prose p {
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    article.legal-prose p {
      text-align: justify;
      text-justify: inter-word;
    }
  }

  article.legal-prose ul {
    list-style: disc outside;
    margin: 1rem 0 1.5rem;
    padding-left: 1.5rem;
  }

  article.legal-prose ol {
    list-style: decimal outside;
    margin: 1rem 0 1.5rem;
    padding-left: 1.5rem;
  }

  article.legal-prose li {
    margin-bottom: 0.65rem;
    padding-left: 0.25rem;
    text-align: left;
  }

  article.legal-prose li::marker {
    color: #dcd4ff;
  }

  article.legal-prose .legal-contact-lines p {
    margin-bottom: 0.65rem;
    text-align: left;
  }

  article.legal-prose strong {
    color: #ffffff;
    font-weight: 500;
  }

  article.legal-prose a {
    color: #dcd4ff;
    text-decoration: none;
    transition: color 180ms ease;
  }

  article.legal-prose a:hover {
    color: #ffffff;
    text-decoration: underline;
  }

  article.legal-prose hr {
    border: none;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(220, 212, 255, 0),
      rgba(220, 212, 255, 0.25),
      rgba(220, 212, 255, 0)
    );
    margin: 2.5rem 0;
  }
</style>
