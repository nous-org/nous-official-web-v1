---
import Layout from '@/layouts/Layout.astro';
import ContentPagesHero from '@/components/ui/ContentPagesHero.astro';
import AboutBento from '@/components/ui/AboutBento.astro';
import FoundersSection from '@/components/ui/FoundersSection.astro';
import ContactCta from '@/components/ui/ContactCta.astro';
import MainCta from '@/components/ui/MainCta.astro';
import BreadcrumbSchema from '@/components/seo/BreadCrumbs.astro';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about' }
];

---

<Layout 
    title="About Us - Nous Technologies"
    backgroundType="primary"
    useContainer={true}
    showAurora={false}
    paddingType="normal"
    canonical="/about"
    ogImage="/images/og-default.jpg"
    tags={['about us', 'company', 'team', 'mission', 'AI experts']}
    includeOrganizationSchema={false}
>
    <BreadcrumbSchema items={breadcrumbs} />
    <ContentPagesHero />
    <AboutBento />
    <FoundersSection />
    <MainCta />

    <ContactCta />
</Layout>
