---
import SectionContact from "@/components/ui-main-components/Contact.astro";
import Layout from "@/layouts/Layout.astro";
import type { Button } from "@/types/callToAction";
import ContentPagesHero from "@/components/ui/ContentPagesHero.astro";
import BreadcrumbSchema from "@/components/seo/BreadCrumbs.astro";


interface Hero {
    title: string;
    subtitle: string;
    text: string;
    buttons: Button[];
}

const breadcrumbs = [
    { name: "Home", url: "/" },
    { name: "Contact", url: "/contact" },
];

// Schema para información de contacto
const contactSchema = {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    mainEntity: {
        "@type": "Organization",
        name: "Nous Technologies",
        contactPoint: {
            "@type": "ContactPoint",
            telephone: "+506-6186-5634",
            contactType: "customer service",
            email: "contacto@nous.cr",
            availableLanguage: ["English", "Spanish"],
        },
    },
};

const HERO: Hero = {
    title: "Any question about?",
    subtitle: "Let's talk about your next big project",
    text: "We're here to listen, advise, and create tailored solutions with AI, web development, and intelligent software. Contact us and let's take the first step together!",
    buttons: [
        {
            text: "Home",
            variant: "secondary",
            href: "/",
            scheduleIcon: false,
            strokeColor: "#060114",
            arrowIcon: true,
            target: "_self",
            ariaLabel: "Home",
        },
        {
            text: "Services",
            variant: "secondaryTurquoise",
            href: "/services",
            scheduleIcon: false,
            strokeColor: "#060114",
            arrowIcon: false,
            target: "_self",
            ariaLabel: "Services",
        },
    ],
};
const { title, subtitle, text, buttons } = HERO;
---

<Layout
    title="Nous Technologies: AI & Automation"
    backgroundType="primary"
    showAurora={false}
    useContainer={true}
    canonical="/contact"
    ogImage="/images/og-default.jpg"
    tags={[
        "contact",
        "consultation",
        "quote",
        "AI consulting",
        "web development",
    ]}
    customSchema={contactSchema}
    includeOrganizationSchema={false}
>
    <BreadcrumbSchema items={breadcrumbs} />
    <ContentPagesHero
        title={title}
        subtitle={subtitle}
        text={text}
        buttons={buttons}
    />
    <SectionContact />
</Layout>
