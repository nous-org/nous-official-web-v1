---
import SectionContact from "@/components/ui-main-components/Contact.astro";
import Layout from "@/layouts/Layout.astro";
import type { Button } from "@/types/callToAction";
import ContentPagesHero from "@/components/ui/ContentPagesHero.astro";
import BreadcrumbSchema from "@/components/seo/BreadCrumbs.astro";

export const prerender = false;

interface Hero {
    title: string;
    subtitle: string;
    text: string;
    buttons: Button[];
}

const breadcrumbs = [
    { name: "Home", url: "/" },
    { name: "Contact", url: "/contact" },
];

// Schema para información de contacto
const contactSchema = {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    mainEntity: {
        "@type": "Organization",
        name: "Nous Technologies",
        contactPoint: {
            "@type": "ContactPoint",
            telephone: "+506-6186-5634",
            contactType: "customer service",
            email: "contacto@nous.cr",
            availableLanguage: ["English", "Spanish"],
        },
    },
};

const HERO: Hero = {
    title: "Contact NOUS",
    subtitle: "Tell us what you want to build",
    text: "We’ll listen, outline a simple plan, and move at your pace—automation if it saves hours, web if it drives growth.",
    buttons: [
        {
            text: "Start the conversation",
            variant: "primary",
            href: "#form",
            scheduleIcon: false,
            strokeColor: "#060114",
            arrowIcon: true,
            target: "_self",
            ariaLabel: "Start the conversation",
        },
        {
            text: "See services",
            variant: "primaryPurple",
            href: "/services",
            scheduleIcon: false,
            strokeColor: "#060114",
            arrowIcon: false,
            target: "_self",
            ariaLabel: "Services",
        },
    ],
};
const { title, subtitle, text, buttons } = HERO;
---

<Layout
    title="Nous Technologies: AI & Automation"
    backgroundType="primary"
    showAurora={false}
    useContainer={true}
    canonical="/contact"
    ogImage="/images/og-default.jpg"
    tags={[
        "contact",
        "consultation", 
        "quote",
        "AI consulting",
        "web development",
        "contacto",
        "consultoría",
        "cotización",
        "consultoría en IA",
        "desarrollo web",
        "contactar",
        "presupuesto",
        "consulta gratuita",
        "asesoría técnica",
    ]}
    customSchema={contactSchema}
    includeOrganizationSchema={false}
>
    <BreadcrumbSchema items={breadcrumbs} />
    <ContentPagesHero
        title={title}
        subtitle={subtitle}
        text={text}
        buttons={buttons}
    />
    <SectionContact />
</Layout>
