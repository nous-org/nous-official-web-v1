---
import type { ServiceCard } from '@/types/serviceCards';
import ButtonVariant from '@/components/ui/Buttons/ButtonVariant.astro';
import Frame from '@/components/icons/Frame.svg';
interface Props {
    serviceCards?: ServiceCard[];
}

const { serviceCards = [{
    title: 'IT Consulting',
    description: "We offer IT consulting services focused on identifying opportunities for technological improvement, optimizing infrastructure, and aligning digital solutions with your business's strategic objectives.",
    img: Frame.src,
    buttons: [{
        text: 'Schedule',
        variant: 'secondaryTurquoise',
        href: '#',
        target: '_self',
        ariaLabel: 'Button'
    }, {
        text: 'Contact',
        variant: 'secondary',
        href: '#',
        target: '_self',
        ariaLabel: 'Button'
    }]
},
{
    title: 'IT Consulting',
    description: "We offer IT consulting services focused on identifying opportunities for technological improvement, optimizing infrastructure, and aligning digital solutions with your business's strategic objectives.",
    img: Frame.src,
    buttons: [{
        text: 'Schedule',
        variant: 'secondaryTurquoise',
        href: '#',
        target: '_self',
        ariaLabel: 'Button'
    }, {
        text: 'Contact',
        variant: 'secondary',
        href: '#',
        target: '_self',
        ariaLabel: 'Button'
    }]
},
{
    title: 'IT Consulting',
    description: "We offer IT consulting services focused on identifying opportunities for technological improvement, optimizing infrastructure, and aligning digital solutions with your business's strategic objectives.",
    img: Frame.src,
    buttons: [{
        text: 'Schedule',
        variant: 'secondaryTurquoise',
        href: '#',
        target: '_self',
        ariaLabel: 'Button'
    }, {
        text: 'Contact',
        variant: 'secondary',
        href: '#',
        target: '_self',
        ariaLabel: 'Button'
    }]
},
] } = Astro.props;
---

<section class="flex gap-4 mb-32">
    {serviceCards.map((serviceCard) => (
        <div class="flex flex-col w-1/3 gap-4 border border-primary-turquoise rounded-xl px-8 py-6 text-white ">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-full flex overflow-hidden items-center justify-center shadow-[inset_0px_0px_10px_0_rgba(0,0,0,0.1)] shadow-primary-turquoise">
                    <img src={serviceCard.img} alt={serviceCard.title} />
                </div>
                <h2 class="text-xl font-semibold">{serviceCard.title}</h2>
            </div>
            <p class="text-lg">{serviceCard.description}</p>
            <div>
                <div class="flex justify-between">
                {serviceCard.buttons.map((button) => (
                    

                    <ButtonVariant
                        text={button.text}
                        variant={button.variant}
                        href={button.href}
                        target={button.target}
                        ariaLabel={button.ariaLabel}
                        />
                    ))}
                    </div>
            </div>
        </div>
    ))}
</section>