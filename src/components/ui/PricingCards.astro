---
interface PricingCard {
    title: string;
    description: string;
    subtitle: string;
    price: string;
    features: string[];
    popular?: boolean;
}

const PRICING_CARDS: PricingCard[] = [
    {
        title: "AI-Powered Automation",
        description: "Smart AI automation tools to boost your business efficiency.",
        subtitle: "Price depends on the scope of the project",
        price: "Consult for price",
        features: [
            "AI Chatbot Integration",
            "Email Automation",
            "Lead Generation System",
            "Content Creation Tools",
            "Analytics Dashboard",
            "24/7 Support"
        ],
    },
    {
        title: "Custom Web Development",
        description: "Tailored web development solutions for your unique needs.",
        subtitle: "Price depends on the scope of the project",
        price: "Consult for price",
        features: [
            "Responsive Web Design",
            "Modern Framework Integration",
            "SEO Optimization",
            "Performance Optimization",
            "Content Management System",
            "Ongoing Maintenance"
        ],
        popular: true,
    },
    {
        title: "Technology Consulting",
        description: "Expert technology consulting to guide your business growth.",
        subtitle: "Price depends on the scope of the project",
        price: "Consult for price",
        features: [
            "Strategic Technology Planning",
            "Infrastructure Assessment",
            "Digital Transformation",
            "Security Audit",
            "Team Training",
            "Implementation Support"
        ],
    }
];
---

<section class="py-16 sm:py-20 md:py-24 lg:py-32" aria-labelledby="pricing-heading">

    <h2 id="pricing-heading" class="mt-32 mb-4 md:text-4xl text-2xl font-bold text-white text-center appear-subtle">We adapt to the needs of all types of companies to provide high-quality solutions.</h2>
    <p class="text-neutral-400 text-center text-lg leading-relaxed max-w-3xl mx-auto mb-20 appear-subtle">Quick, no-obligation consultation. See how AI and automation can save time and improve efficiency.</p>
    <div class="px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 sm:gap-8 lg:gap-10 max-w-7xl mx-auto appear-left">
            {PRICING_CARDS.map((card, index) => (
                <article
                    class={`group relative flex flex-col border mb-8 p-6 transition-all duration-300 bg-gradient-to-br from-primary-black to-primary-turquoise/10 rounded-xl ${
                        card.popular
                            ? 'border-primary-turquoise/60 shadow-lg shadow-primary-turquoise/10 md:scale-105 z-10'
                            : 'border-neutral-600 hover:shadow-lg hover:shadow-primary-purple/10'
                    }`}
                    aria-labelledby={`pricing-${index}-title`}
                >


                    {card.popular && (
                        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
                            <span class="bg-primary-turquoise text-primary-black px-4 py-2 rounded-full text-sm font-bold uppercase tracking-wider">
                                Most Popular
                            </span>
                        </div>
                    )}


                    <header class="text-center mb-6 sm:mb-8">
                        <h3
                            id={`pricing-${index}-title`}
                            class={`text-2xl sm:text-3xl lg:text-4xl font-bold mb-8 transition-colors duration-300 ${
                                card.popular
                                    ? 'text-primary-turquoise'
                                    : 'text-white md:group-hover:text-primary-purple'
                            }`}
                        >
                            {card.title}
                        </h3>


                        <div class="pricing-section">
                            <p class="text-sm text-neutral-500 mb-1">{card.subtitle}</p>
                            <div class="flex items-baseline justify-center gap-2">
                                <span class={`text-3xl sm:text-3xl lg:text-3xl font-bold transition-colors duration-300 ${
                                    card.popular
                                        ? 'text-primary-turquoise'
                                        : 'text-white md:group-hover:text-primary-purple'
                                }`}>
                                    {card.price}
                                </span>

                            </div>
                        </div>
                    </header>


                    <div class="flex-1 mb-8">
                        <h4 class="text-lg font-semibold text-white mb-4">What's can be included:</h4>
                        <ul class="space-y-3" role="list">
                            {card.features.map((feature) => (
                                <li class="flex items-start gap-3">
                                    <svg
                                        class={`w-5 h-5 mt-0.5 flex-shrink-0 transition-colors duration-300 ${
                                            card.popular
                                                ? 'text-primary-turquoise'
                                                : 'text-neutral-400 group-hover:text-primary-turquoise'
                                        }`}
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                        aria-hidden="true"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                    <span class="text-sm sm:text-base text-neutral-300 group-hover:text-neutral-200 transition-colors duration-300">
                                        {feature}
                                    </span>
                                </li>
                            ))}
                        </ul>
                    </div>


                    <div class="mt-auto flex justify-center">
                        <a
                            href={card.popular ? '/contact' : '/contact'}
                            class={`w-full text-center py-2 sm:py-2 px-6 rounded-lg sm:rounded-xl font-semibold text-base sm:text-lg transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-primary-black cursor-pointer ${
                                card.popular
                                    ? 'bg-primary-turquoise text-primary-black hover:bg-primary-turquoise/90 focus:ring-primary-turquoise shadow-lg'
                                    : 'bg-transparent border-2 border-primary-purple text-primary-purple hover:bg-primary-purple hover:text-primary-black focus:ring-primary-purple'
                            }`}
                            aria-label={`Get started with ${card.title} plan`}
                        >
                            {card.popular ? 'Get Started' : 'Contact Us'}
                        </a>
                    </div>
                </article>
            ))}
        </div>
            <p class="text-sm text-neutral-400 mt-12 text-center">Important: Prices may vary depending on scope.</p>
    </div>
</section>