---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;

const dustParticles = [
  { lag: 0.012, drift: -18, phase: 0.4, opacity: 0.82, shimmer: 9, radius: 19, color: '#F8F5FF' },
  { lag: 0.018, drift: 28, phase: 1.2, opacity: 0.7, shimmer: 14, radius: 13, color: '#DCD4FF' },
  { lag: 0.024, drift: -42, phase: 2.1, opacity: 0.56, shimmer: 18, radius: 10, color: '#BBA7FF' },
  { lag: 0.031, drift: 12, phase: 2.8, opacity: 0.64, shimmer: 12, radius: 15, color: '#EEE9FF' },
  { lag: 0.038, drift: 46, phase: 3.5, opacity: 0.48, shimmer: 22, radius: 8, color: '#9B7CFF' },
  { lag: 0.045, drift: -24, phase: 4.1, opacity: 0.52, shimmer: 16, radius: 12, color: '#DCD4FF' },
  { lag: 0.052, drift: 62, phase: 4.8, opacity: 0.38, shimmer: 24, radius: 7, color: '#BBA7FF' },
  { lag: 0.059, drift: -58, phase: 5.4, opacity: 0.4, shimmer: 20, radius: 9, color: '#F8F5FF' },
  { lag: 0.067, drift: 34, phase: 6.2, opacity: 0.32, shimmer: 25, radius: 6, color: '#9B7CFF' },
  { lag: 0.075, drift: -12, phase: 6.9, opacity: 0.36, shimmer: 18, radius: 8, color: '#DCD4FF' },
  { lag: 0.083, drift: 52, phase: 7.5, opacity: 0.28, shimmer: 28, radius: 5, color: '#BBA7FF' },
  { lag: 0.092, drift: -36, phase: 8.3, opacity: 0.3, shimmer: 23, radius: 6, color: '#EEE9FF' },
  { lag: 0.101, drift: 18, phase: 9.1, opacity: 0.24, shimmer: 19, radius: 5, color: '#F8F5FF' },
  { lag: 0.111, drift: -66, phase: 9.8, opacity: 0.2, shimmer: 26, radius: 4, color: '#9B7CFF' },
];
---

<svg
  class={`hero-nous-logo ${className}`}
  viewBox="0 0 4755 1001"
  fill="none"
  overflow="visible"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="NOUS"
>
  <path d="M1000.96 500.48V1000.96H916.94V500.48C916.94 270.84 730.13 84.0198 500.48 84.0198C270.83 84.0198 84.02 270.83 84.02 500.48V1000.96H0V500.48C0 224.08 224.08 0 500.48 0C776.88 0 1000.96 224.08 1000.96 500.48Z" fill="currentColor"/>
  <path d="M2252.15 500.48C2252.15 776.88 2028.07 1000.96 1751.67 1000.96C1475.27 1000.96 1251.19 776.88 1251.19 500.48C1251.19 224.08 1475.27 0 1751.67 0C2028.07 0 2252.15 224.08 2252.15 500.48ZM2168.13 500.48C2168.13 270.84 1981.32 84.0198 1751.67 84.0198C1522.02 84.0198 1335.21 270.83 1335.21 500.48C1335.21 730.13 1522.02 916.94 1751.67 916.94C1981.32 916.94 2168.13 730.12 2168.13 500.48Z" fill="currentColor"/>
  <path d="M3419.32 0H3503.34V500.48C3503.34 776.88 3279.26 1000.96 3002.86 1000.96C2726.46 1000.96 2502.38 776.88 2502.38 500.48V0H2586.4V500.48C2586.4 730.12 2773.21 916.94 3002.86 916.94C3232.51 916.94 3419.32 730.12 3419.32 500.48V0Z" fill="currentColor"/>
  <path d="M4754.53 0V84.0198H4024.82C3921.58 84.0198 3837.59 168 3837.59 271.24C3837.59 374.48 3921.58 458.47 4024.82 458.47H4483.28C4633.09 458.47 4754.53 579.91 4754.53 729.72C4754.53 879.53 4633.09 1000.97 4483.28 1000.97H3753.57V916.95H4483.28C4586.52 916.95 4670.51 832.97 4670.51 729.73C4670.51 626.49 4586.52 542.5 4483.28 542.5H4024.82C3875.01 542.5 3753.57 421.06 3753.57 271.25C3753.57 121.44 3875.01 0 4024.82 0H4754.53Z" fill="currentColor"/>

  <g class="hero-nous-comet">
    <circle class="hero-nous-comet-settle-glow" cx="1751.68" cy="500.48" r="118" fill="url(#hero-nous-settle-glow)" />
    {dustParticles.map((particle) => (
      <circle
        class="hero-nous-comet-dust"
        cx="1751.68"
        cy="500.48"
        r={particle.radius}
        fill={particle.color}
        data-lag={particle.lag}
        data-drift={particle.drift}
        data-phase={particle.phase}
        data-opacity={particle.opacity}
        data-shimmer={particle.shimmer}
      />
    ))}
    <circle class="hero-nous-comet-dot hero-nous-comet-motion" cx="1751.68" cy="500.48" r="62.86" fill="currentColor" />
  </g>

  <defs>
    <radialGradient id="hero-nous-settle-glow" cx="0" cy="0" r="1" gradientUnits="objectBoundingBox">
      <stop stop-color="#FFFFFF" stop-opacity="0.92"/>
      <stop offset="0.42" stop-color="#DCD4FF" stop-opacity="0.44"/>
      <stop offset="0.76" stop-color="#9B7CFF" stop-opacity="0.16"/>
      <stop offset="1" stop-color="#DCD4FF" stop-opacity="0"/>
    </radialGradient>
  </defs>
</svg>

<style>
  .hero-nous-logo {
    color: #ffffff;
    overflow: visible;
  }

  .hero-nous-comet {
    pointer-events: none;
    transform-origin: center;
  }

  .hero-nous-comet-dust,
  .hero-nous-comet-settle-glow {
    opacity: 0;
    will-change: opacity, transform;
    mix-blend-mode: screen;
  }

  .hero-nous-comet-dust {
    filter: drop-shadow(0 0 10px rgba(220, 212, 255, 0.55));
  }

  .hero-nous-comet-dot {
    will-change: fill, opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-nous-comet-dust,
    .hero-nous-comet-settle-glow {
      opacity: 0;
    }
  }
</style>

<script>
  const ORBIT_START_ANGLE = Math.PI * 0.95;
  const ORBIT_TURNS = 2;
  const ORBIT_ENTRY_ARC = Math.PI;
  const ORBIT_ARC = Math.PI * 2 * ORBIT_TURNS;
  const ORBIT_RETURN_ARC = Math.PI;
  const ORBIT_TOTAL_ARC = ORBIT_ENTRY_ARC + ORBIT_ARC + ORBIT_RETURN_ARC;
  const DOT_CENTER_X = 1751.68;
  const DOT_CENTER_Y = 500.48;
  const ORBIT_RADIUS_X = 650;
  const ORBIT_RADIUS_Y = 260;
  const ORBIT_ROTATION = -58 * (Math.PI / 180);
  const EXIT_END = ORBIT_ENTRY_ARC / ORBIT_TOTAL_ARC;
  const RETURN_START = (ORBIT_ENTRY_ARC + ORBIT_ARC) / ORBIT_TOTAL_ARC;
  const DUST_BASE_OPACITY = 0.72;
  const SETTLE_BLINK_DURATION = 1180;
  const ANIMATION_VERSION = "fluid-orbit-v5";

  type HeroNousWindow = Window & {
    __heroNousCometCleanups?: WeakMap<SVGSVGElement, () => void>;
  };

  type DustParticle = {
    element: SVGCircleElement;
    lag: number;
    drift: number;
    phase: number;
    opacity: number;
    shimmer: number;
  };

  const clamp01 = (value: number) => Math.min(Math.max(value, 0), 1);

  const smootherStep = (value: number) => {
    const clamped = clamp01(value);
    return clamped * clamped * clamped * (clamped * (clamped * 6 - 15) + 10);
  };

  const vectorForAngle = (angle: number) => {
    const ellipseX = Math.cos(angle) * ORBIT_RADIUS_X;
    const ellipseY = Math.sin(angle) * ORBIT_RADIUS_Y;
    const rotationCos = Math.cos(ORBIT_ROTATION);
    const rotationSin = Math.sin(ORBIT_ROTATION);

    return {
      x: ellipseX * rotationCos - ellipseY * rotationSin,
      y: ellipseX * rotationSin + ellipseY * rotationCos,
    };
  };

  const orbitPoint = (angle: number, radiusScale = 1) => {
    const point = vectorForAngle(angle);
    return {
      x: point.x * radiusScale,
      y: point.y * radiusScale,
    };
  };

  const tangentForAngle = (angle: number) => {
    const rotationCos = Math.cos(ORBIT_ROTATION);
    const rotationSin = Math.sin(ORBIT_ROTATION);
    const derivativeX = -Math.sin(angle) * ORBIT_RADIUS_X;
    const derivativeY = Math.cos(angle) * ORBIT_RADIUS_Y;
    const x = derivativeX * rotationCos - derivativeY * rotationSin;
    const y = derivativeX * rotationSin + derivativeY * rotationCos;
    const length = Math.hypot(x, y) || 1;

    return {
      x: x / length,
      y: y / length,
    };
  };

  const angleForProgress = (progress: number) =>
    ORBIT_START_ANGLE + ORBIT_TOTAL_ARC * clamp01(progress);

  const radiusForProgress = (progress: number) => {
    if (progress < EXIT_END) return smootherStep(progress / EXIT_END);
    if (progress > RETURN_START) return 1 - smootherStep((progress - RETURN_START) / (1 - RETURN_START));
    return 1;
  };

  const positionForProgress = (progress: number) => {
    const clampedProgress = clamp01(progress);
    return orbitPoint(angleForProgress(clampedProgress), radiusForProgress(clampedProgress));
  };

  const centeredScaleTransform = (scaleX: number, scaleY: number) =>
    `translate(${DOT_CENTER_X} ${DOT_CENTER_Y}) scale(${scaleX} ${scaleY}) translate(${-DOT_CENTER_X} ${-DOT_CENTER_Y})`;

  const eyeBlinkAmountForProgress = (progress: number) => {
    const firstBlink = Math.max(0, 1 - Math.abs(progress - 0.22) / 0.16);
    const secondBlink = Math.max(0, 1 - Math.abs(progress - 0.68) / 0.16);
    return smootherStep(Math.max(firstBlink, secondBlink));
  };

  const dustOpacityForProgress = (progress: number, particle: DustParticle) => {
    const radiusScale = radiusForProgress(progress);
    const sparkle = 0.74 + Math.sin(progress * Math.PI * 12 + particle.phase) * 0.26;
    return radiusScale * DUST_BASE_OPACITY * particle.opacity * sparkle;
  };

  const positionDust = (particle: DustParticle, progress: number) => {
    const dustProgress = Math.max(progress - particle.lag, 0);
    const angle = angleForProgress(dustProgress);
    const point = positionForProgress(dustProgress);
    const tangent = tangentForAngle(angle);
    const normal = { x: -tangent.y, y: tangent.x };
    const shimmer = Math.sin(progress * Math.PI * 8 + particle.phase) * particle.shimmer;

    return {
      x: point.x + normal.x * particle.drift + tangent.x * shimmer,
      y: point.y + normal.y * particle.drift + tangent.y * shimmer,
      progress: dustProgress,
    };
  };

  function initHeroNousComet() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const heroNousWindow = window as HeroNousWindow;
    const cleanupRegistry =
      heroNousWindow.__heroNousCometCleanups ?? new WeakMap<SVGSVGElement, () => void>();
    heroNousWindow.__heroNousCometCleanups = cleanupRegistry;

    document.querySelectorAll<SVGSVGElement>(".hero-nous-logo").forEach((logo) => {
      if (logo.dataset.cometAnimationVersion === ANIMATION_VERSION) return;

      cleanupRegistry.get(logo)?.();
      logo.dataset.cometAnimationVersion = ANIMATION_VERSION;

      const dot = logo.querySelector<SVGCircleElement>(".hero-nous-comet-dot");
      const settleGlow = logo.querySelector<SVGCircleElement>(".hero-nous-comet-settle-glow");
      const dustParticles = Array.from(logo.querySelectorAll<SVGCircleElement>(".hero-nous-comet-dust")).map(
        (element) => ({
          element,
          lag: Number(element.dataset.lag ?? "0.02"),
          drift: Number(element.dataset.drift ?? "0"),
          phase: Number(element.dataset.phase ?? "0"),
          opacity: Number(element.dataset.opacity ?? "0.5"),
          shimmer: Number(element.dataset.shimmer ?? "12"),
        })
      );
      if (!dot || !settleGlow || dustParticles.length === 0) return;

      const duration = 11800;
      const delay = 450;
      let animationFrame = 0;
      let blinkFrame = 0;

      const resetComet = () => {
        dot.setAttribute("transform", "translate(0 0)");
        dot.style.fill = "";
        dot.style.opacity = "1";
        settleGlow.style.opacity = "0";
        dustParticles.forEach(({ element }) => {
          element.setAttribute("transform", "translate(0 0)");
          element.style.opacity = "0";
        });
      };

      const runSettleBlink = (onComplete: () => void) => {
        const blinkStart = performance.now();

        const blink = (currentTime: number) => {
          const progress = Math.min((currentTime - blinkStart) / SETTLE_BLINK_DURATION, 1);
          const blinkAmount = eyeBlinkAmountForProgress(progress);
          const scaleX = 1 + blinkAmount * 0.08;
          const scaleY = 1 - blinkAmount * 0.9;

          dot.setAttribute("transform", centeredScaleTransform(scaleX, scaleY));
          dot.style.opacity = "1";
          dot.style.fill = "#F8F5FF";
          settleGlow.style.opacity = "0";

          if (progress < 1) {
            blinkFrame = requestAnimationFrame(blink);
          } else {
            resetComet();
            onComplete();
          }
        };

        blinkFrame = requestAnimationFrame(blink);
      };

      const timeout = window.setTimeout(() => {
        const startTime = performance.now();

        const animate = (currentTime: number) => {
          const progress = Math.min((currentTime - startTime) / duration, 1);
          const { x, y } = positionForProgress(progress);
          const movingScale = radiusForProgress(progress);

          dot.setAttribute("transform", `translate(${x} ${y})`);
          dot.style.fill = movingScale > 0.02 ? "#F8F5FF" : "";

          settleGlow.style.opacity = "0";

          dustParticles.forEach((particle) => {
            const dustPoint = positionDust(particle, progress);
            particle.element.setAttribute("transform", `translate(${dustPoint.x} ${dustPoint.y})`);
            particle.element.style.opacity = dustOpacityForProgress(dustPoint.progress, particle).toString();
          });

          if (progress < 1) {
            animationFrame = requestAnimationFrame(animate);
          } else {
            dustParticles.forEach(({ element }) => {
              element.style.opacity = "0";
            });
            runSettleBlink(() => {
              cleanupRegistry.delete(logo);
            });
          }
        };

        animationFrame = requestAnimationFrame(animate);
      }, delay);

      cleanupRegistry.set(logo, () => {
        window.clearTimeout(timeout);
        cancelAnimationFrame(animationFrame);
        cancelAnimationFrame(blinkFrame);
        resetComet();
      });
    });
  }

  document.addEventListener("astro:page-load", initHeroNousComet);
  initHeroNousComet();
</script>
