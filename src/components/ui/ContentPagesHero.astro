---
import ColorDivider from "@/components/ui/ColorDivider.astro";
import ButtonVariant from "@/components/ui/Buttons/ButtonVariant.astro";
import type { Button } from "@/types/callToAction";
import { ShootingStars } from "../react/ShootingStars";
import { StarsBackground } from "../react/StarBackground";

interface Props {
    colorDivider?: "primary-purple" | "primary-turquoise";
    title?: string;
    text?: string;
    subtitle?: string;
    buttons?: Button[];
}

const {
    colorDivider = "primary-purple",
    title = "About NOUS",
    text = "",
    subtitle = "",
    buttons = [],
} = Astro.props as Props;
---

<section
    id="page-hero"
    aria-labelledby="page-heading"
    class="relative mx-auto max-w-5xl px-4 pb-16 pt-36 text-center sm:pb-20 sm:pt-44"
>
    <article class="relative isolate overflow-hidden rounded-[2rem] border border-outline/15 bg-white/[0.025] px-6 py-12 shadow-[0_24px_80px_rgba(0,0,0,0.24)] backdrop-blur sm:px-10 sm:py-16">
        <div class="pointer-events-none absolute inset-x-8 top-0 h-px bg-gradient-to-r from-transparent via-outline/60 to-transparent" aria-hidden="true" />
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(220,212,255,0.16),transparent_42%)]" aria-hidden="true" />

        <header class="relative z-10 mx-auto max-w-4xl animate-blurred-fade-in">
            <span class="inline-flex rounded-full border border-outline/25 bg-white/[0.04] px-4 py-1.5 text-xs font-medium uppercase tracking-[0.18em] text-outline">
                NOUS
            </span>
            <h1
                id="page-heading"
                class="mt-6 text-4xl font-medium leading-[1.05] tracking-normal text-white sm:text-6xl md:text-7xl"
            >
                {title}
            </h1>

            {subtitle && (
                <p class="mx-auto mt-5 max-w-3xl text-lg font-normal leading-relaxed text-neutral-300 sm:text-2xl">
                    {subtitle}
                </p>
            )}

            {text && (
                <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-neutral-400 sm:text-lg">
                    {text}
                </p>
            )}
        </header>

        {buttons.length > 0 && (
            <>
                <div class="relative z-10 py-8">
                    <ColorDivider colorDivider={colorDivider} />
                </div>

                <nav
                    aria-label="Primary actions"
                    class="relative z-10 flex flex-col justify-center gap-4 animate-blurred-fade-in sm:flex-row"
                >
                    {
                        buttons.map((button) => (
                            <ButtonVariant
                                scheduleIcon={button.scheduleIcon}
                                arrowIcon={button.arrowIcon}
                                text={button.text}
                                variant={button.variant}
                                href={button.href}
                                target={button.target}
                                strokeColor={button.strokeColor}
                                ariaLabel={button.ariaLabel}
                            />
                        ))
                    }
                </nav>
            </>
        )}
    </article>
</section>
<!-- Background Effects with Proper Masking -->
<div class="absolute inset-0 pointer-events-none overflow-hidden z-[-1]">
    <div
        class="absolute inset-0 [mask-image:radial-gradient(ellipse_at_center_10%,black_20%,transparent_70%)] opacity-60"
    >
        <ShootingStars client:only="react"
            minDelay={1000}
            maxDelay={1500}
            starColor="#DCD4FF"
            starHeight={2}
            starWidth={20}
        />
        <StarsBackground client:only="react" />
    </div>
</div>
