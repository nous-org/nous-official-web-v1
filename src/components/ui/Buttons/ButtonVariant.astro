---

import ScheduleIcon from "@/components/icons/ScheduleIcon.astro"
import ArrowIcon from "@/components/icons/arrowIcon.astro"

interface Props {
  href?: string;
  text?: string;
  variant?: "primary" | "secondary" | "primaryPurple" | "secondaryTurquoise" | "darkBlue";
  className?: string;
  scheduleIcon?: boolean;
  arrowIcon?: boolean;
  strokeColor?: string;
  width?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  ariaLabel?: string;
  rel?: string;
  rounded?: string;
  justify?: string;
}

const {
  target = "_self",
  width = "auto",
  href="/contact",
  text,
  variant = "primary",
  className = "",
  scheduleIcon = false,
  arrowIcon = false,
  strokeColor = "#DCD4FF",
  ariaLabel,
  rel,
  rounded = "full",
  justify = "center",
} = Astro.props;

const radiusClass = rounded === "md" ? "rounded-md" : rounded === "lg" ? "rounded-lg" : "rounded-full";
const justifyClass = justify === "between" ? "justify-between" : justify === "start" ? "justify-start" : justify === "end" ? "justify-end" : "justify-center";
const widthClass = width === "full" ? "md:w-full" : width === "fit" ? "md:w-fit" : "";
const baseStyles = `min-h-11 px-5 py-2.5 text-sm sm:text-base font-medium tracking-normal ${radiusClass} transition-all duration-200 group inline-flex ${justifyClass} items-center gap-2 w-auto ${widthClass} cursor-pointer border focus:outline-none focus-visible:ring-2 focus-visible:ring-outline/60 focus-visible:ring-offset-2 focus-visible:ring-offset-primary-black active:scale-[0.98]`;
const computedRel = rel || (target === "_blank" ? "noopener noreferrer" : undefined);
const computedAriaLabel = ariaLabel && text && ariaLabel.includes(text) ? ariaLabel : undefined;

const variants = {
  primary: "border-transparent bg-outline text-primary-black shadow-sm shadow-outline/10 hover:bg-hover hover:shadow-outline/20",
  secondary:
    "border-white/10 bg-white/5 text-neutral-100 hover:border-outline/50 hover:bg-white/10",
  primaryPurple:
    "border-outline/45 bg-transparent text-outline hover:bg-outline/10 hover:border-outline",
  secondaryTurquoise:
    "border-primary-turquoise/45 bg-transparent text-primary-turquoise hover:bg-primary-turquoise/10 hover:border-primary-turquoise",
  darkBlue:
    "border-white/10 bg-primary-blue/80 text-outline hover:bg-primary-blue",
};
---


<a
  href={href}
  aria-label={computedAriaLabel}
  target={target}
  rel={computedRel}
  class:list={[baseStyles, variants[variant], className]}
>
  {text}
  {
    scheduleIcon && (
      <ScheduleIcon strokeColor={strokeColor}/>
    )
  }
  {
    arrowIcon && (
      <ArrowIcon strokeColor={strokeColor}/>
    )
  }
</a>
