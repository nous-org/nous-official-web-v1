---
interface Button {
    text?: string;
    href?: string;
    className?: string;
    target?: '_blank' | '_self' | '_parent' | '_top';
    ariaLabel?: string;
}

interface Props {
    button?: Button;
    className?: string;
    ariaLabel?: string;
}

//default button
const defaultButton: Button = {
    text: 'Talk with us',
    href: '/contact',
    className: '',
    target: '_self',
    ariaLabel: 'Button'
};

//default props
const defaultProps: Props = {
    button: defaultButton,
    className: '',
    ariaLabel: 'Button'
};

const {
    button = defaultButton,
    className = '',
    ariaLabel = 'Button'
} = Astro.props;
---

<!-- Desktop version - shows text -->
<a
    class={[
        'hidden lg:flex px-8 py-2 rounded-full font-medium text-lg transition-colors duration-300 cursor-pointer items-center',
        'bg-transparent text-[#A894FF] border border-[#6E3BFF] hover:bg-[#6E3BFF]/20 hover:text-white',
        className
    ].join(' ')}
    href={button.href}
    target={button.target}
    aria-label={button.ariaLabel}
>
    {button.text}
</a>

<!-- Mobile/Tablet version - shows message icon -->
<a
    class={[
        'hidden md:flex lg:hidden px-3 py-3 rounded-full transition-colors duration-300 cursor-pointer items-center justify-center',
        'bg-transparent text-[#A894FF] border border-[#6E3BFF] hover:bg-[#6E3BFF]/20 hover:text-white',
        className
    ].join(' ')}
    href={button.href}
    target={button.target}
    aria-label="Send message"
>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
    </svg>
</a>

