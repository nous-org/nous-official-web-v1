---
interface Props {
  content: string;
}

import { sanitizeHtml } from '@/lib/security';

const { content } = Astro.props;

// Check if content is HTML or markdown
function isHTML(content: string): boolean {
  return /<\/?[a-z][\s\S]*>/i.test(content);
}

// Process HTML to add Tailwind classes to lists
function processListHTML(html: string) {
  return html
    .replace(/<ul>/g, '<ul class="list-disc list-outside ml-6 mb-6 space-y-2 text-neutral-300">')
    .replace(/<ol>/g, '<ol class="list-decimal list-outside ml-6 mb-6 space-y-2 text-neutral-300">')
    .replace(/<li>/g, '<li class="pl-1 text-neutral-300">');
}

function isMarkdownSyntax(line: string): boolean {
  return /^(#{1,6}\s|[-*+]\s|\d+\.\s|>\s|```|---$|<)/.test(line);
}

function isLikelyHeading(line: string, previousLine: string | undefined, nextLine: string | undefined): boolean {
  const trimmed = line.trim();
  const previous = previousLine?.trim() ?? '';
  const next = nextLine?.trim() ?? '';
  const words = trimmed.split(/\s+/).filter(Boolean);

  if (!trimmed || !next || isMarkdownSyntax(trimmed)) return false;
  if (words.length < 2 || words.length > 9 || trimmed.length > 72) return false;
  if (/[.!?;:,]$/.test(trimmed)) return false;
  if (/^[a-z]/.test(trimmed)) return false;
  if (previous && !/[.!?]$/.test(previous)) return false;

  return true;
}

function normalizeMarkdownHeadings(markdown: string): string {
  const lines = markdown.replace(/\r\n/g, '\n').split('\n');

  return lines
    .map((line, index) => {
      if (isLikelyHeading(line, lines[index - 1], lines[index + 1])) {
        return `## ${line.trim()}`;
      }

      return line;
    })
    .join('\n');
}

// Import marked for markdown parsing
import { marked } from 'marked';

let processedContent = '';
let isHtmlContent = isHTML(content);

if (isHtmlContent) {
  // Process HTML content
  processedContent = processListHTML(sanitizeHtml(content));
} else {
  // Parse markdown to HTML
  processedContent = await marked.parse(normalizeMarkdownHeadings(content));
  processedContent = processListHTML(sanitizeHtml(processedContent));
}
---

<div class="blog-content-processed" set:html={processedContent}></div>

<style is:global>
  .blog-content-processed h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 500;
    color: #ffffff;
    margin-bottom: 1.5rem;
    margin-top: 0;
    line-height: 1.08;
    letter-spacing: 0;
  }
  
  .blog-content-processed h2 {
    border-top: 1px solid rgba(220, 212, 255, 0.18);
    color: #f4f0ff;
    font-size: clamp(1.45rem, 2.5vw, 1.9rem);
    font-weight: 560;
    letter-spacing: 0;
    line-height: 1.16;
    margin-bottom: 1.1rem;
    margin-top: 3.6rem;
    padding-top: 2.2rem;
  }
  
  .blog-content-processed h3 {
    border-top: 1px solid rgba(220, 212, 255, 0.14);
    color: #f4f0ff;
    font-size: clamp(1.35rem, 2.1vw, 1.75rem);
    font-weight: 560;
    letter-spacing: 0;
    line-height: 1.18;
    margin-bottom: 1rem;
    margin-top: 3.2rem;
    padding-top: 2rem;
  }

  .blog-content-processed h3:first-child {
    border-top: 0;
    margin-top: 0;
    padding-top: 0;
  }
  
  .blog-content-processed p {
    color: rgba(229, 229, 229, 0.78);
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.96;
    margin-bottom: 1.65rem;
    text-align: justify;
  }
  
  .blog-content-processed hr {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, rgba(220, 212, 255, 0), rgba(220, 212, 255, 0.24), rgba(220, 212, 255, 0));
    margin: 2.75rem 0;
  }

  .blog-content-processed strong {
    color: #ffffff;
    font-weight: 560;
  }

  .blog-content-processed a {
    color: #dcd4ff;
    text-decoration: none;
  }

  .blog-content-processed a:hover {
    color: #ffffff;
    text-decoration: underline;
  }

  .blog-content-processed blockquote {
    border-left: 3px solid rgba(220, 212, 255, 0.6);
    color: rgba(229, 229, 229, 0.74);
    font-style: italic;
    margin: 2rem 0;
    padding-left: 1rem;
  }

  @media (max-width: 640px) {
    .blog-content-processed p {
      font-size: 1rem;
      line-height: 1.78;
      text-align: left;
    }
  }
</style>
