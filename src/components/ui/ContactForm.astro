---
import GradientTittle from '@/components/ui/Tittles/GradientTittle.astro'
import Inputs from '@/components/ui/Inputs.astro'
import SubmitButton from '@/components/ui/Buttons/SubmitButton.astro'

const chips = [
  { id: 'software-consulting', label: 'Software Consulting', value: 'software-consulting' },
  { id: 'web-development', label: 'Web Development', value: 'web-development' },
  { id: 'ai-automation', label: 'AI Automation', value: 'ai-automation' },
];
---

<div class="w-auto">
  <GradientTittle title="Let's build your next big idea Contact us today!"/>
  
  <!-- Message containers -->
  <div id="success-message" class="hidden mb-4 p-4 border border-primary-turquoise text-primary-turquoise rounded-lg">
    <p class="font-medium">Thank you for your message! We'll get back to you within 24 hours.</p>
  </div>
  
  <div id="error-message" class="hidden mb-4 p-4 border border-red-400 text-red-700 rounded-lg">
    <p class="font-medium" id="error-text">There was an error sending your message. Please try again.</p>
  </div>
  
  <form id="contact-form" class="flex flex-col gap-4" method="POST" action="/api/contact">
    <div class="flex flex-col gap-4">
      <label for="interests" class="block text-lg font-medium text-gray-400">I'm interested in:</label>
      <div class="flex flex-wrap gap-2">
        {chips.map((chip) => (
          <div>
            <input 
              type="checkbox" 
              id={chip.id} 
              name="interests" 
              value={chip.value}
              class="sr-only peer"
            />
            <label 
              for={chip.id} 
              class="inline-flex items-center px-4 py-2 rounded-full border-2 border-gray-300 
                     cursor-pointer transition-all duration-200 
                     hover:border-primary-turquoise hover:bg-primary-turquoise hover:text-primary-blue
                     peer-checked:bg-primary-turquoise peer-checked:text-primary-blue peer-checked:border-primary-turquoise"
            >
              {chip.label}
            </label>
          </div>
        ))}
      </div>
    </div>
    
    <Inputs type="text" placeholder="Name" name="name" />
    <Inputs type="email" placeholder="Email" name="email" />
    <Inputs type="text" placeholder="Subject" name="subject" />
    <Inputs type="textarea" placeholder="Message" name="message" />
    
    <div class="flex justify-center mt-2">
      <SubmitButton 
        id="submit-button"
        type="submit" 
        text="Send" 
        icon={true} 
        variant="secondary"
      />
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMessage = document.getElementById('success-message') as HTMLElement;
    const errorMessage = document.getElementById('error-message') as HTMLElement;
    const errorText = document.getElementById('error-text') as HTMLElement;
  
    if (!form) {
      console.error('Contact form not found');
      return;
    }
  
    let isSubmitting = false;
  
    // Buscar el botón submit de forma más flexible
    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    
    if (!submitButton) {
      console.warn('Submit button not found, but form will still work');
    }
  
    function hideMessages() {
      successMessage?.classList.add('hidden');
      errorMessage?.classList.add('hidden');
    }
  
    function showSuccess() {
      hideMessages();
      successMessage?.classList.remove('hidden');
      successMessage?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  
    function showError(message: string) {
      hideMessages();
      if (errorText) {
        errorText.textContent = message;
      }
      errorMessage?.classList.remove('hidden');
      errorMessage?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  
    function setButtonLoading(loading: boolean) {
      if (submitButton) {
        if (loading) {
          submitButton.textContent = 'Sending...';
          submitButton.disabled = true;
          submitButton.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
          submitButton.textContent = 'Send';
          submitButton.disabled = false;
          submitButton.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      }
    }
  
    // INTERCEPTAR TODO TIPO DE ENVÍO
    form.addEventListener('submit', function(e) {
  
      
      // BLOQUEAR COMPLETAMENTE el envío nativo
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
  
      if (isSubmitting) {
        console.log('Already submitting, blocked');
        return false;
      }
  
      isSubmitting = true;
      handleFormSubmission();
      return false;
    });
  
    // INTERCEPTAR clicks en botones submit
    if (submitButton) {
      submitButton.addEventListener('click', function(e) {
       
        e.preventDefault();
        e.stopPropagation();
        
        if (isSubmitting) return false;
        
        // Disparar el evento submit del form (que será interceptado arriba)
        const submitEvent = new Event('submit', { bubbles: true, cancelable: true });
        form.dispatchEvent(submitEvent);
        return false;
      });
    }
  
    // INTERCEPTAR Enter en inputs
    form.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && e.target instanceof HTMLInputElement) {
              e.preventDefault();
        e.stopPropagation();
        
        if (!isSubmitting) {
          const submitEvent = new Event('submit', { bubbles: true, cancelable: true });
          form.dispatchEvent(submitEvent);
        }
        return false;
      }
    });
  
    async function handleFormSubmission() {
     ;
      
      try {
        hideMessages();
        setButtonLoading(true);
  
        const formData = new FormData(form);
        
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });
  
        if (!response.ok) {
          throw new Error(`Server error: ${response.status}`);
        }
  
        const result = await response.json();
  
        if (result.success) {
          showSuccess();
          form.reset();
                } else {
          throw new Error(result.message || 'Failed to send message');
        }
  
      } catch (error) {
        console.error('❌ Error:', error);
        
        let errorMessage = 'There was an error sending your message. Please try again.';
        if (error instanceof Error) {
          errorMessage = error.message;
        }
        showError(errorMessage);
        
      } finally {
        setButtonLoading(false);
        isSubmitting = false;
      }
    }
  
   
  });
</script>