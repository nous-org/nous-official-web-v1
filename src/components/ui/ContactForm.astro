---
import GradientTittle from "@/components/ui/Tittles/GradientTittle.astro";
import Inputs from "@/components/ui/Inputs.astro";
import SubmitButton from "@/components/ui/Buttons/SubmitButton.astro";

const chips = [
  {
    id: "ai-strategy",
    label: "AI strategy",
    value: "ai-strategy",
  },
  { id: "automation-agents", label: "Automation & agents", value: "automation-agents" },
  { id: "systems-integrations", label: "Systems & integrations", value: "systems-integrations" },
  { id: "training-adoption", label: "Training & adoption", value: "training-adoption" },
  { id: "not-sure", label: "Not sure yet", value: "not-sure" },
];
---

<div class="w-auto">
  <GradientTittle title="Let’s find your highest-leverage AI opportunity." subHead="Hermes, our customer service agent, will establish first contact, ask a few initial questions, and help clarify the next step." />
  <!-- Message containers -->
  <div
    id="success-message"
    class="hidden mb-4 p-4 border border-primary-turquoise text-primary-turquoise rounded-lg"
  >
    <p class="font-medium">
      Thanks. We received your message. Hermes will establish first contact shortly.
    </p>
  </div>

  <div
    id="error-message"
    class="hidden mb-4 p-4 border border-red-400 text-red-700 rounded-lg"
  >
    <p class="font-medium" id="error-text">
      Something went wrong. Please try again or contact us directly at hello@nous.cr.
    </p>
  </div>

  <form
    id="contact-form"
    class="flex flex-col gap-5"
    method="POST"
    action="/api/contact"
  >
    <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
    <div class="flex flex-col gap-3">
      <span id="home-interests-label" class="block text-lg font-medium text-white">What are you exploring?</span>
      <div class="grid grid-cols-1 gap-2 sm:grid-cols-2" role="group" aria-labelledby="home-interests-label">
        {
          chips.map((chip) => (
            <div class:list={["min-w-0", chip.value === "not-sure" && "sm:col-span-2 sm:mx-auto sm:w-[calc(50%-0.25rem)]"]}>
              <input
                type="checkbox"
                id={chip.id}
                name="interests"
                value={chip.value}
                class="sr-only peer"
              />
              <label
                for={chip.id}
                class="inline-flex w-full items-center justify-center px-4 py-2 rounded-full border-2 border-gray-400
                     cursor-pointer transition-all duration-400
                     hover:border-outline hover:bg-outline/10 hover:text-white
                     peer-checked:bg-outline peer-checked:text-primary-black peer-checked:border-outline"
              >
                {chip.label}
              </label>
            </div>
          ))
        }
      </div>
    </div>

    <Inputs id="Name" type="text" placeholder="Roberto Pereira Ugalde" name="name" />
    <Inputs id="E-mail" type="email" placeholder="roberto@nous.cr" name="email" />
    <Inputs id="Phone number" type="tel" placeholder="+50661865634" name="phone" required={false} />
    <Inputs
      id="Preferred contact method"
      type="radio"
      name="preferredContact"
      placeholder="Preferred Contact Method"
      options={[
        { value: "email", label: "E-mail" },
        { value: "whatsapp", label: "WhatsApp" },
      ]}
    />
    <Inputs id="Subject" type="text" placeholder="AI for customer support" name="subject" />
    <Inputs id="Message" type="textarea" placeholder="Tell us what your organization is trying to improve, automate, understand, or build." name="message" />

    <div class="flex justify-start">
      <SubmitButton
        id="submit-button"
        type="submit"
        text="Send message"
        icon={true}
        variant="primary"
        className="w-full sm:w-auto"
      />
    </div>
  </form>
</div>

<script is:inline lang="ts">

  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("contact-form");
    if (!form) return;
    if (form.dataset.initialized === "true") return;
    form.dataset.initialized = "true";

    const submitBtn = form.querySelector('button[type="submit"]');
    const okBox = document.getElementById("success-message");
    const errBox = document.getElementById("error-message");
    const errText = document.getElementById("error-text");

    let busy = false;

    function hideMsgs() {
      okBox?.classList.add("hidden");
      errBox?.classList.add("hidden");
    }
    function showOK() {
      hideMsgs();
      okBox?.classList.remove("hidden");
    }
    function showErr(msg) {
      hideMsgs();
      if (errText) errText.textContent = msg;
      errBox?.classList.remove("hidden");
    }
    function setBtnLoading(v) {
      if (!(submitBtn instanceof HTMLButtonElement)) return;
      submitBtn.classList.toggle("is-loading", v);
      submitBtn.disabled = v;
      submitBtn.setAttribute("aria-busy", v ? "true" : "false");
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      e.stopImmediatePropagation();
      if (busy) return;
      busy = true;
      send();
    });

    async function send() {
      try {
        hideMsgs();
        setBtnLoading(true);
        const res = await fetch("/api/contact", {
          method: "POST",
          body: new FormData(form),
        });
        const json = await res.json();
        if (!res.ok || !json.success)
          throw new Error(json.message || `HTTP ${res.status}`);
        showOK();
        form.reset();
      } catch (err) {
        showErr(err instanceof Error ? err.message : "Unexpected error");
      } finally {
        setBtnLoading(false);
        busy = false;
      }
    }
  });
</script>
