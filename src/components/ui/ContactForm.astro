---
import GradientTittle from "@/components/ui/Tittles/GradientTittle.astro";
import Inputs from "@/components/ui/Inputs.astro";
import SubmitButton from "@/components/ui/Buttons/SubmitButton.astro";
import ContactFormClientScript from "@/components/ui/ContactFormClientScript.astro";
import { normalizeLocale, type Locale } from "@/lib/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props as Props;
const currentLocale = normalizeLocale(locale);
const isEs = currentLocale === "es";
const copy = isEs
  ? {
      title: "Encontremos la oportunidad de IA con mayor impacto para tu organización.",
      subHead: "Hermes, nuestro agente de servicio al cliente, establecerá el primer contacto, hará algunas preguntas iniciales y ayudará a aclarar el siguiente paso.",
      success: "Gracias. Recibimos tu mensaje. Hermes establecerá el primer contacto pronto.",
      error: "Algo salió mal. Inténtalo de nuevo o contáctanos directamente en hello@nous.cr.",
      exploring: "¿Qué estás explorando?",
      name: "Nombre",
      email: "E-mail",
      phone: "Número de teléfono",
      preferred: "Método de contacto preferido",
      subject: "Asunto",
      message: "Mensaje",
      subjectPlaceholder: "IA para atención al cliente",
      messagePlaceholder: "Cuéntanos qué está intentando mejorar, automatizar, entender o construir tu organización.",
      send: "Enviar mensaje",
      sending: "Enviando…",
      unexpected: "Error inesperado",
      chips: [
        { id: "ai-strategy", label: "Estrategia de IA", value: "ai-strategy" },
        { id: "automation-agents", label: "Automatización y agentes", value: "automation-agents" },
        { id: "systems-integrations", label: "Sistemas e integraciones", value: "systems-integrations" },
        { id: "training-adoption", label: "Capacitación y adopción", value: "training-adoption" },
        { id: "not-sure", label: "Todavía no estoy seguro", value: "not-sure" },
      ],
    }
  : {
      title: "Let’s find your highest-leverage AI opportunity.",
      subHead: "Hermes, our customer service agent, will establish first contact, ask a few initial questions, and help clarify the next step.",
      success: "Thanks. We received your message. Hermes will establish first contact shortly.",
      error: "Something went wrong. Please try again or contact us directly at hello@nous.cr.",
      exploring: "What are you exploring?",
      name: "Name",
      email: "E-mail",
      phone: "Phone number",
      preferred: "Preferred contact method",
      subject: "Subject",
      message: "Message",
      subjectPlaceholder: "AI for customer support",
      messagePlaceholder: "Tell us what your organization is trying to improve, automate, understand, or build.",
      send: "Send message",
      sending: "Sending…",
      unexpected: "Unexpected error",
      chips: [
        { id: "ai-strategy", label: "AI strategy", value: "ai-strategy" },
        { id: "automation-agents", label: "Automation & agents", value: "automation-agents" },
        { id: "systems-integrations", label: "Systems & integrations", value: "systems-integrations" },
        { id: "training-adoption", label: "Training & adoption", value: "training-adoption" },
        { id: "not-sure", label: "Not sure yet", value: "not-sure" },
      ],
    };
---

<div class="w-auto" data-contact-form-root>
  <GradientTittle title={copy.title} subHead={copy.subHead} />
  <!-- Message containers -->
  <div
    id="success-message"
    data-contact-success
    role="status"
    aria-live="polite"
    class="hidden mb-4 p-4 border border-primary-turquoise text-primary-turquoise rounded-lg"
  >
    <p class="font-medium" data-contact-success-text>
      {copy.success}
    </p>
  </div>

  <div
    id="error-message"
    data-contact-error
    role="alert"
    aria-live="polite"
    class="hidden mb-4 p-4 border border-red-400 text-red-700 rounded-lg"
  >
    <p class="font-medium" id="error-text" data-contact-error-text>
      {copy.error}
    </p>
  </div>

  <form
    id="contact-form"
    class="flex flex-col gap-5"
    method="POST"
    action="/api/contact"
    data-unexpected-error={copy.unexpected}
    data-contact-form
    data-locale={currentLocale}
  >
    <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
    <input type="hidden" name="locale" value={currentLocale} />
    <div class="flex flex-col gap-3">
      <span id="home-interests-label" class="block text-lg font-medium text-white">{copy.exploring}</span>
      <div
        class="grid grid-cols-1 gap-2 sm:grid-cols-2"
        role="group"
        aria-labelledby="home-interests-label"
        aria-describedby="home-interests-error"
        aria-invalid="false"
        data-fieldset="interests"
      >
        {
          copy.chips.map((chip) => (
            <div class:list={["min-w-0", chip.value === "not-sure" && "sm:col-span-2 sm:mx-auto sm:w-[calc(50%-0.25rem)]"]}>
              <input
                type="checkbox"
                id={chip.id}
                name="interests"
                value={chip.value}
                class="sr-only peer"
                aria-describedby="home-interests-error"
                aria-invalid="false"
              />
              <label
                for={chip.id}
                data-validation-choice="interests"
                class="inline-flex w-full items-center justify-center px-4 py-2 rounded-full border-2 border-gray-400
                     cursor-pointer transition-all duration-400
                     hover:border-outline hover:bg-outline/10 hover:text-white
                     peer-checked:bg-outline peer-checked:text-primary-black peer-checked:border-outline"
              >
                {chip.label}
              </label>
            </div>
          ))
        }
      </div>
      <p id="home-interests-error" data-error-for="interests" class="hidden text-sm leading-relaxed text-red-300" aria-live="polite"></p>
    </div>

    <Inputs id={copy.name} type="text" placeholder="Roberto Pereira Ugalde" name="name" />
    <Inputs id={copy.email} type="email" placeholder="roberto@nous.cr" name="email" />
    <Inputs id={copy.phone} type="tel" placeholder="+50661865634" name="phone" />
    <Inputs
      id={copy.preferred}
      type="radio"
      name="preferredContact"
      placeholder="Preferred Contact Method"
      options={[
        { value: "email", label: "E-mail" },
        { value: "whatsapp", label: "WhatsApp" },
      ]}
    />
    <Inputs id={copy.subject} type="text" placeholder={copy.subjectPlaceholder} name="subject" />
    <Inputs
      id={copy.message}
      type="textarea"
      placeholder={copy.messagePlaceholder}
      name="message"
      minlength={10}
      maxlength={2000}
    />

    <div class="flex justify-start">
      <SubmitButton
        id="submit-button"
        type="submit"
        text={copy.send}
        loadingText={copy.sending}
        icon={true}
        variant="primary"
        className="w-full sm:w-auto"
      />
    </div>
  </form>
</div>

<ContactFormClientScript />
