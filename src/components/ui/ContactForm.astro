---
import GradientTittle from "@/components/ui/Tittles/GradientTittle.astro";
import Inputs from "@/components/ui/Inputs.astro";
import SubmitButton from "@/components/ui/Buttons/SubmitButton.astro";

const chips = [
  {
    id: "software-consulting",
    label: "Software Consulting",
    value: "software-consulting",
  },
  { id: "web-development", label: "Web Development", value: "web-development" },
  { id: "ai-automation", label: "AI Automation", value: "ai-automation" },
];
---

<div class="w-auto">
  <GradientTittle title="Let's build your next big idea Contact us today!" />

  <!-- Message containers -->
  <div
    id="success-message"
    class="hidden mb-4 p-4 border border-primary-turquoise text-primary-turquoise rounded-lg"
  >
    <p class="font-medium">
      Thank you for your message! We'll get back to you within 24 hours.
    </p>
  </div>

  <div
    id="error-message"
    class="hidden mb-4 p-4 border border-red-400 text-red-700 rounded-lg"
  >
    <p class="font-medium" id="error-text">
      There was an error sending your message. Please try again.
    </p>
  </div>

  <form
    id="contact-form"
    class="flex flex-col gap-4"
    method="POST"
    action="/api/contact"
  >
    <div class="flex flex-col gap-4">
      <label for="interests" class="block text-lg font-medium text-gray-400"
        >I'm interested in:</label
      >
      <div class="flex flex-wrap gap-2">
        {
          chips.map((chip) => (
            <div>
              <input
                type="checkbox"
                id={chip.id}
                name="interests"
                value={chip.value}
                class="sr-only peer"
              />
              <label
                for={chip.id}
                class="inline-flex items-center px-4 py-2 rounded-full border-2 border-gray-300 
                     cursor-pointer transition-all duration-200 
                     hover:border-primary-turquoise hover:bg-primary-turquoise hover:text-primary-blue
                     peer-checked:bg-primary-turquoise peer-checked:text-primary-blue peer-checked:border-primary-turquoise"
              >
                {chip.label}
              </label>
            </div>
          ))
        }
      </div>
    </div>

    <Inputs type="text" placeholder="Name" name="name" />
    <Inputs type="email" placeholder="Email" name="email" />
    <Inputs type="text" placeholder="Subject" name="subject" />
    <Inputs type="textarea" placeholder="Message" name="message" />

    <div class="flex justify-center mt-2">
      <SubmitButton
        id="submit-button"
        type="submit"
        text="Send"
        icon={true}
        variant="secondary"
      />
    </div>
  </form>
</div>

<script is:inline lang="ts">
  
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("contact-form");
    if (!form) return;

    const submitBtn = form.querySelector('button[type="submit"]');
    const okBox = document.getElementById("success-message");
    const errBox = document.getElementById("error-message");
    const errText = document.getElementById("error-text");

    let busy = false;

    function hideMsgs() {
      okBox?.classList.add("hidden");
      errBox?.classList.add("hidden");
    }
    function showOK() {
      hideMsgs();
      okBox?.classList.remove("hidden");
    }
    function showErr(msg) {
      hideMsgs();
      if (errText) errText.textContent = msg;
      errBox?.classList.remove("hidden");
    }
    function setBtnLoading(v) {
      if (!(submitBtn instanceof HTMLButtonElement)) return;
      submitBtn.classList.toggle("is-loading", v);  
      submitBtn.disabled = v;                       
      submitBtn.setAttribute("aria-busy", v ? "true" : "false");
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      e.stopImmediatePropagation();
      if (busy) return;
      busy = true;
      send();
    });

    async function send() {
      try {
        hideMsgs();
        setBtnLoading(true);
        const res = await fetch("/api/contact", {
          method: "POST",
          body: new FormData(form),
        });
        const json = await res.json();
        if (!res.ok || !json.success)
          throw new Error(json.message || `HTTP ${res.status}`);
        showOK();
        form.reset();
      } catch (err) {
        showErr(err instanceof Error ? err.message : "Unexpected error");
      } finally {
        setBtnLoading(false);
        busy = false;
      }
    }
  });
</script>
