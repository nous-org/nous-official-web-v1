---


interface Props {
    type: 'text' | 'email' | 'password' | 'number' | 'tel' | 'url' | 'search' | 'date' | 'time' | 'datetime-local' | 'month' | 'week' | 'color' | 'file' | 'hidden' | 'image' | 'range' | 'reset' | 'submit' | 'button' | 'checkbox' | 'radio' | 'textarea' | 'select';
    placeholder: string;
    className?: string;
    id?: string;
    textareaClassName?: string;
    selectClassName?: string;
    name?: string;
    options?: Array<{ value: string; label: string; }>;
    required?: boolean;
    autocomplete?: string;
}
const defaultClassName = 'w-full rounded-lg border border-neutral-700 bg-white/[0.03] px-4 py-3 text-base sm:text-lg font-normal text-white placeholder:text-neutral-500 transition-colors duration-200 hover:border-outline/70 focus:border-outline focus:outline-none focus:ring-2 focus:ring-outline/15';
const defaultTextareaClassName = 'w-full rounded-lg border border-neutral-700 bg-white/[0.03] px-4 py-3 text-base sm:text-lg font-normal text-white placeholder:text-neutral-500 transition-colors duration-200 hover:border-outline/70 focus:border-outline focus:outline-none focus:ring-2 focus:ring-outline/15 min-h-[20dvh]';
const defaultSelectClassName = `
  w-full
  p-2 pb-4
  border-b border-neutral-600
  bg-primary-blue
  text-neutral-400
  focus:border-outline hover:border-outline/70
  focus:text-white hover:text-white
  transition-colors duration-300
  font-medium text-lg
  cursor-pointer
  focus:outline-none
  appearance-none
`;

const inferAutocomplete = (inputName?: string, inputType?: string) => {
    if (inputName === 'name') return 'name';
    if (inputName === 'email' || inputType === 'email') return 'email';
    if (inputName === 'phone' || inputType === 'tel') return 'tel';
    if (inputName === 'subject') return 'off';
    return undefined;
};

const { type, placeholder, className = defaultClassName, textareaClassName = defaultTextareaClassName, selectClassName = defaultSelectClassName, name, id, options = [], required = true, autocomplete } = Astro.props;
const computedAutocomplete = autocomplete ?? inferAutocomplete(name, type);
---

{type === 'textarea' ? (
    <div class="space-y-2">
        <label for={name} class="block text-base sm:text-lg font-medium text-gray-200 mb-2">{id}:</label>
        <textarea id={name} placeholder={placeholder} class={textareaClassName} name={name} required={required}></textarea>
    </div>
) : type === 'select' ? (
    <div class="space-y-2">
        <label for={name} class="block text-lg font-medium text-gray-200 mb-2">{id}:</label>
        <div class="relative">
            <select id={name} name={name} class={selectClassName} required={required}>
                <option value="" disabled selected>{placeholder}</option>
                {options.map((option) => (
                    <option value={option.value}>{option.label}</option>
                ))}
            </select>
            <!-- Custom dropdown arrow -->
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </div>
        </div>
    </div>
) : type === 'radio' ? (
    <div class="space-y-2">
        <fieldset class="space-y-3">
            <legend class="block text-base sm:text-lg font-medium text-gray-200 mb-3">{id}:</legend>
            <div class="flex flex-wrap gap-2">
                {options.map((option) => (
                    <label
                        for={`${name}-${option.value}`}
                        class="group cursor-pointer"
                    >
                        <input
                            type="radio"
                            id={`${name}-${option.value}`}
                            name={name}
                            value={option.value}
                            class="sr-only peer"
                            required={required}
                        />
                        <span class="inline-flex min-h-11 items-center justify-center rounded-full border border-neutral-700 bg-white/[0.03] px-4 py-2 text-sm font-normal text-neutral-300 transition-colors duration-200 group-hover:border-outline/70 group-hover:text-white peer-focus-visible:ring-2 peer-focus-visible:ring-outline/40 peer-checked:border-outline peer-checked:bg-outline peer-checked:text-primary-black">
                            {option.label}
                        </span>
                    </label>
                ))}
            </div>
        </fieldset>
    </div>
) : (
    <div class="space-y-2">
        <label for={name} class="block text-base sm:text-lg font-medium text-gray-200 mb-2">{id}:</label>
        <input id={name} type={type} placeholder={placeholder} class={className} name={name} required={required} autocomplete={computedAutocomplete} />
    </div>
)}
