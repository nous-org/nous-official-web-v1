---


interface Props {
    type: 'text' | 'email' | 'password' | 'number' | 'tel' | 'url' | 'search' | 'date' | 'time' | 'datetime-local' | 'month' | 'week' | 'color' | 'file' | 'hidden' | 'image' | 'range' | 'reset' | 'submit' | 'button' | 'checkbox' | 'radio' | 'textarea' | 'select' | 'radio';
    placeholder: string;
    className?: string;
    id?: string;
    textareaClassName?: string;
    selectClassName?: string;
    name?: string;
    options?: Array<{ value: string; label: string; }>;
}
const defaultClassName = 'w-full p-2 pb-4 bg-transparent border-b border-neutral-600 focus:border-accent hover:border-accent transition-colors duration-300 font-medium text-lg cursor-pointer focus:outline-none';
const defaultTextareaClassName = 'w-full p-2 pb-6 bg-primary-black border border-neutral-600 focus:border-accent hover:border-accent transition-colors duration-300 font-medium text-lg cursor-pointer focus:outline-none rounded-md min-h-[20dvh]';
const defaultSelectClassName = `
  w-full
  p-2 pb-4
  border-b border-neutral-600
  bg-primary-blue
  text-neutral-400
  focus:border-accent hover:border-accent
  focus:text-white hover:text-white
  transition-colors duration-300
  font-medium text-lg
  cursor-pointer
  focus:outline-none
  appearance-none
`;

const { type, placeholder, className = defaultClassName, textareaClassName = defaultTextareaClassName, selectClassName = defaultSelectClassName, name, id, options = [] } = Astro.props;
---

{type === 'textarea' ? (
    <>
        <label for={name} class="block text-lg font-medium text-gray-200 mb-2">{id}:</label>
        <textarea placeholder={placeholder} class={textareaClassName} name={name} required autocomplete="off"></textarea>
    </>
) : type === 'select' ? (
    <>
        <label for={name} class="block text-lg font-medium text-gray-200 mb-2">{id}:</label>
        <div class="relative">
            <select name={name} class={selectClassName} required>
                <option value="" disabled selected>{placeholder}</option>
                {options.map((option) => (
                    <option value={option.value}>{option.label}</option>
                ))}
            </select>
            <!-- Custom dropdown arrow -->
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </div>
        </div>
    </>
) : type === 'radio' ? (
    <>
        <fieldset class="space-y-3">
            <legend class="block text-lg font-medium text-gray-200 mb-4">{id}:</legend>
            {options.map((option) => (
                <label 
                    for={`${name}-${option.value}`}
                    class="flex items-center space-x-3 group cursor-pointer"
                >
                    <div class="relative">
                        <input 
                            type="radio" 
                            id={`${name}-${option.value}`}
                            name={name} 
                            value={option.value}
                            class="sr-only peer"
                            required
                        />
                        <div class="w-5 h-5 border-2 border-neutral-600 rounded-full peer-checked:border-accent peer-checked:bg-accent peer-checked:shadow-[0_0_10px_0_rgba(255,255,255,0.2)] peer-focus:border-accent group-hover:border-accent transition-colors duration-300 flex items-center justify-center">
                            <div class="w-2.5 h-2.5 bg-accent rounded-full opacity-0 peer-checked:opacity-100 transition-opacity duration-300"></div>
                        </div>
                    </div>
                    <span class="text-lg font-medium text-neutral-300 group-hover:text-white transition-colors duration-300">
                        {option.label}
                    </span>
                </label>
            ))}
        </fieldset>
    </>
) : (
    <>
        <label for={name} class="block text-lg font-medium text-gray-200 mb-2">{id}:</label>
        <input type={type} placeholder={placeholder} class={className} name={name} required autocomplete="off" />
    </>
)}
