---


interface Props {
    type: 'text' | 'email' | 'password' | 'number' | 'tel' | 'url' | 'search' | 'date' | 'time' | 'datetime-local' | 'month' | 'week' | 'color' | 'file' | 'hidden' | 'image' | 'range' | 'reset' | 'submit' | 'button' | 'checkbox' | 'radio' | 'textarea';
    placeholder: string;
    className?: string;
    textareaClassName?: string;
}
const defaultClassName = 'w-full p-4 pb-6 bg-transparent border-b border-neutral-600 focus:border-primary-turquoise hover:border-primary-turquoise transition-colors duration-300 font-medium text-lg cursor-pointer focus:outline-none';
;
const defaultTextareaClassName = 'w-full p-4 pb-6 bg-primary-black border border-neutral-600 focus:border-primary-turquoise hover:border-primary-turquoise transition-colors duration-300 font-medium text-lg cursor-pointer focus:outline-none rounded-md min-h-[20dvh]';

const { type, placeholder, className = defaultClassName, textareaClassName = defaultTextareaClassName } = Astro.props;
---

{type === 'textarea' ? (
    <textarea placeholder={placeholder} class={textareaClassName}></textarea>
) : (
    <input type={type} placeholder={placeholder} class={className} />
)}
