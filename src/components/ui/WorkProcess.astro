---
import ButtonVariant from "./Buttons/ButtonVariant.astro";

// Work Process Component for NOUS
// Showcases our 4-step methodology: Listen → Design → Deliver → Support
// Built with semantic HTML, accessibility, and responsive design

interface ProcessStep {
    step: number;
    title: string;
    description: string;
    icon: string;
    color: "accent";
}

const PROCESS_STEPS: ProcessStep[] = [
    {
        step: 1,
        title: "Listen",
        description: "We first listen to your specific needs, understanding your challenges and goals to create the perfect foundation.",
        icon: "ear",
        color: "accent"
    },
    {
        step: 2,
        title: "Design",
        description: "Then design a clear and viable solution, mapping out every detail to ensure optimal results and user experience.",
        icon: "design",
        color: "accent"
    },
    {
        step: 3,
        title: "Deliver",
        description: "Deliver a professional implementation with cutting-edge technology, following best practices and quality standards.",
        icon: "rocket",
        color: "accent"
    },
    {
        step: 4,
        title: "Support",
        description: "Finally provide ongoing support to ensure real results, with maintenance, updates, and continuous optimization.",
        icon: "support",
        color: "accent"
    }
];

---

<section class="py-16 sm:py-20 md:py-24 lg:py-32 appear-subtle" aria-labelledby="process-heading">
    <div class=" max-w-7xl mx-auto">
        <!-- Section Header -->
        <header class="text-center mb-12 sm:mb-16 lg:mb-20">
            <h2 id="process-heading" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 sm:mb-6">
                Our Work Methodology
            </h2>

        </header>

        <!-- Process Steps Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-10 lg:gap-6 relative">
            <!-- Connection Lines (Desktop Only) -->
            <div class="hidden lg:block absolute top-24 left-0 right-0 h-0.5 bg-gradient-to-r from-accent via-primary-purple to-accent opacity-30" aria-hidden="true"></div>

            {PROCESS_STEPS.map((step, index) => (
                <article
                    class="group relative flex flex-col items-center p-4 rounded-xl border border-outline bg-gradient-to-br from-primary-black/80 to-accent/10 backdrop-blur-sm transition-all duration-50"
                    aria-labelledby={`step-${step.step}-title`}
                >
                    <!-- Step Number Badge -->
                    <div class={`absolute -top-4 -left-4 w-12 h-12 sm:w-8 sm:h-8 rounded-full flex items-center justify-center text-lg transition-all duration-300 z-10
                        ${step.color === 'accent' ? 'bg-primary-blue border border-outline text-accent ' : ''}
                        ${step.color === 'accent' ? 'bg-primary-blue border border-outline text-accent ' : ''}
                        ${step.color === 'accent' ? 'bg-primary-blue border border-outline text-accent ' : ''}
                        ${step.color === 'accent' ? 'bg-primary-blue border border-outline text-accent ' : ''}
                    `}>
                        {step.step}
                    </div>

                    <!-- Icon Container -->
                    <div class={`w-16 h-16 sm:w-20 sm:h-20 lg:w-16 lg:h-16 rounded-full flex items-center justify-center mb-6 sm:mb-8 transition-all duration-300 group-hover:rotate-12
                        ${step.color === 'accent' ? 'bg-accent/20 border-2 border-accent/40' : ''}
                        ${step.color === 'accent' ? 'bg-accent/20 border-2 border-accent/40' : ''}
                        ${step.color === 'accent' ? 'bg-accent/20 border-2 border-accent/40' : ''}
                        ${step.color === 'accent' ? 'bg-accent/20 border-2 border-accent/40' : ''}
                    `}>
                        <!-- Dynamic SVG Icons -->
                        {step.icon === 'ear' && (
                           <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="#ffffff" stroke="#FFF" stroke-width="1" d="M19.48 9q0 1.671-.54 3.17q-.542 1.5-1.544 2.751q-.14.177-.16.397t.147.367q.17.146.375.108q.203-.037.363-.214q1.092-1.348 1.726-3.027T20.481 9q0-1.884-.634-3.573q-.634-1.688-1.726-3.056q-.16-.177-.363-.214q-.204-.038-.375.109q-.166.146-.147.366t.16.397q1.002 1.252 1.543 2.763q.542 1.512.542 3.208m-9.5 2.116q.896 0 1.506-.613q.61-.612.61-1.503q0-.896-.61-1.506t-1.506-.61t-1.506.61T7.865 9q0 .89.61 1.503t1.506.613M4.558 18.5q-.039-.213-.172-.366q-.134-.153-.347-.153q-.233 0-.386.153q-.153.152-.134.366q.154 1.285 1.137 2.142t2.325.858q1.338 0 2.23-.756q.891-.755 1.397-2.14q.386-1.096.87-1.702t1.845-1.686q1.512-1.212 2.335-2.72T16.48 9q0-2.783-1.859-4.641T9.981 2.5q-2.667 0-4.497 1.695T3.519 8.5q-.019.214.134.357T4.019 9t.347-.143t.153-.357q.135-2.183 1.697-3.591T9.981 3.5q2.317 0 3.909 1.591Q15.48 6.683 15.48 9q0 1.777-.8 3.16q-.8 1.382-2.068 2.351q-1.185.893-1.824 1.687t-1.084 1.96q-.427 1.119-1.04 1.73t-1.683.612q-.883 0-1.576-.568T4.558 18.5"/></svg>
                        )}
                        {step.icon === 'design' && (
                           <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 48 48"><defs><mask id="ipTSettingWeb0"><g fill="none"><path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M24 40H7a3 3 0 0 1-3-3V11a3 3 0 0 1 3-3h34a3 3 0 0 1 3 3v12.059"/><path fill="#555" stroke="#fff" stroke-width="4" d="M4 11a3 3 0 0 1 3-3h34a3 3 0 0 1 3 3v9H4z"/><circle r="2" fill="#fff" transform="matrix(0 -1 -1 0 10 14)"/><circle r="2" fill="#fff" transform="matrix(0 -1 -1 0 16 14)"/><circle cx="37" cy="34" r="3" stroke="#fff" stroke-width="4"/><path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M37 41v-4m0-6v-4m-6.062 10.5l3.464-2m5.196-3l3.464-2m-12.124 0l3.464 2m5.196 3l3.464 2"/></g></mask></defs><path fill="#ffffff" d="M0 0h48v48H0z" mask="url(#ipTSettingWeb0)"/></svg>
                        )}
                        {step.icon === 'rocket' && (
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="#ffffff" d="M6.125 12.15q.65-1.65 1.563-3.175T9.75 6.1l-1.3-.275q-.5-.1-.975.05t-.825.5L3.5 9.525q-.375.375-.288.9t.588.725zm14.7-9.75q-2.65-.125-5.037 1.025T11.525 6.45q-1.2 1.2-2.113 2.6T7.826 12q-.125.325-.125.663t.25.587l3.125 3.125q.25.25.588.25t.662-.125q1.55-.675 2.95-1.588t2.6-2.112q1.875-1.875 3.025-4.262T21.925 3.5q0-.2-.1-.4t-.25-.35t-.35-.25t-.4-.1m-6.35 7.45q-.575-.575-.575-1.412t.575-1.413t1.413-.575t1.412.575t.575 1.413T17.3 9.85t-1.412.575t-1.413-.575m-2.3 8.35l1 2.325q.2.5.725.6t.9-.275l3.15-3.15q.35-.35.5-.837t.05-.988l-.25-1.3q-1.375 1.15-2.887 2.063T12.175 18.2M4.05 16.05q.875-.875 2.125-.888t2.125.863t.875 2.125t-.875 2.125q-1.2 1.2-2.838 1.425t-3.287.45q.225-1.65.463-3.287T4.05 16.05"/></svg>
                        )}
                        {step.icon === 'support' && (
                           <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><path fill="#ffffff" d="M10.5 6h3q0-.625-.437-1.062T12 4.5t-1.062.438T10.5 6m6.5 5.075V6h1q.825 0 1.413.588T20 8v3.3q-.725-.2-1.487-.275t-1.513.05M6 17q-.825 0-1.412-.587T4 15V8q0-.825.588-1.412T6 6h1v11zm2.5 0V6H9q0-1.25.875-2.125T12 3t2.125.875T15 6h.5v5.475q-1.775.675-2.912 2.163T11.1 17zm9.05 2.1h.9v-.25q0-.275.15-.488t.35-.412q.3-.275.525-.6t.225-.75q0-.675-.5-1.138T18 15q-.575 0-1.037.338t-.663.912l.8.35q.075-.325.325-.537T18 15.85t.563.213t.237.537q0 .275-.15.463t-.35.387q-.15.15-.312.3t-.288.35q-.075.15-.112.313t-.038.337zM18 21q.275 0 .463-.187t.187-.463t-.187-.462T18 19.7t-.462.188t-.188.462t.188.463T18 21m0 2q-2.075 0-3.537-1.463T13 18t1.463-3.537T18 13t3.538 1.463T23 18t-1.463 3.538T18 23M2 21v-2h9.1q.1.5.25 1t.35 1z"/></svg>
                        )}
                    </div>

                    <!-- Content -->
                    <header class="mb-4 sm:mb-6">
                        <h3
                            id={`step-${step.step}-title`}
                            class={`text-2xl sm:text-3xl lg:text-4xl font-bold mb-3 sm:mb-4 transition-colors duration-300
                                ${step.color === 'accent' ? 'text-accent' : ''}
                                ${step.color === 'accent' ? 'text-accent' : ''}
                                ${step.color === 'accent' ? 'text-accent' : ''}
                                ${step.color === 'accent' ? 'text-accent' : ''}
                            `}
                        >
                            {step.title}
                        </h3>
                    </header>

                    <p class="text-sm sm:text-base lg:text-lg text-neutral-400 leading-relaxed group-hover:text-neutral-300 transition-colors duration-300">
                        {step.description}
                    </p>

                    <!-- Progress Indicator (Mobile) -->
                    {index < PROCESS_STEPS.length - 1 && (
                        <div class="lg:hidden absolute -bottom-4 left-1/2 transform -translate-x-1/2 w-0.5 h-8 bg-gradient-to-b from-accent to-transparent opacity-30" aria-hidden="true"></div>
                    )}
                </article>
            ))}
        </div>

        <!-- Call to Action -->
        <footer class="text-center mt-5 lg:mt-10">
            <div class="bg-gradient-to-br from-primary-black/50 to-accent/10 border border-outline/50 rounded-xl p-8 sm:p-10 lg:p-12">
                <h3 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-4 sm:mb-6">
                    Ready to Start Your Project?
                </h3>
                <p class="text-lg sm:text-xl text-neutral-400 mb-8 sm:mb-10 max-w-3xl mx-auto leading-relaxed">
                    Let's discuss how our proven methodology can transform your ideas into powerful digital solutions.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center items-center">
                   <ButtonVariant
                   text="Contact us"
                   variant="primary"
                   href="/contact"
                   scheduleIcon={false}
                   strokeColor="#060114"
                   arrowIcon={true}
                   target="_self"
                   ariaLabel="Contact us"/>
                </div>
            </div>
        </footer>
    </div>
</section>
