---
import NousLogo from "@/assets/NousLogo.svg";
import { normalizeLocale, type Locale } from "@/lib/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props as Props;
const currentLocale = normalizeLocale(locale);
const copy = currentLocale === "es"
  ? {
      eyebrow: "Por qué existe NOUS",
      heading: "Las organizaciones necesitan un socio entre los laboratorios de IA y el trabajo que realmente debe cambiar.",
      description:
        "La inteligencia se está volviendo disponible bajo demanda. Los modelos fundacionales seguirán mejorando, pero cada organización debe decidir qué construir con esa inteligencia: nuevos flujos de trabajo, mejores experiencias para clientes, operaciones más fuertes, herramientas internas más inteligentes y sistemas que hagan a las personas más capaces. NOUS ayuda a hacer concreta esa traducción.",
      whatWeDo: "Qué hacemos",
      operatingTitle: "Convertimos la IA en capacidad operativa.",
      operatingDescription:
        "Nuestro trabajo empieza con la organización, no con el modelo. Estudiamos las decisiones, flujos de trabajo, datos, herramientas y momentos de cliente donde la inteligencia puede crear ventaja, y luego construimos la tecnología y el camino de adopción que la hacen útil en el trabajo diario.",
      beliefs: [
        {
          title: "IA primero. Tecnología amplia.",
          description:
            "NOUS lidera con IA, pero construye lo que la transformación necesita: agentes, automatizaciones, aplicaciones, integraciones, flujos de datos, sitios web, herramientas internas y la infraestructura alrededor.",
        },
        {
          title: "Despliegue antes que espectáculo.",
          description:
            "La IA crea valor solo cuando cambia trabajo real. Nos importan los prototipos, pero nos importan más los sistemas útiles que los equipos pueden confiar, adoptar y mejorar.",
        },
        {
          title: "Independientes por diseño.",
          description:
            "La capa de inteligencia avanza rápido. Nos mantenemos atentos a modelos, proveedores y casos de uso para que las organizaciones elijan lo que realmente encaja.",
        },
      ],
      capabilities: [
        "Entender la organización, los flujos y las restricciones.",
        "Identificar dónde la IA puede generar más impacto en el trabajo.",
        "Diseñar la solución, el modelo operativo y el camino de adopción.",
        "Construir agentes, automatizaciones, productos e integraciones.",
        "Desplegar, entrenar, medir y mejorar con el equipo.",
      ],
    }
  : {
      eyebrow: "Why NOUS exists",
      heading: "Organizations need a partner between the AI labs and the work that actually needs to change.",
      description:
        "Intelligence is becoming available on tap. The foundation models will keep improving, but every organization still has to decide what to build with that intelligence: new workflows, better customer experiences, stronger operations, smarter internal tools, and systems that make people more capable. NOUS helps make that translation concrete.",
      whatWeDo: "What we do",
      operatingTitle: "We turn AI into operating capacity.",
      operatingDescription:
        "Our work starts with the organization, not the model. We study the decisions, workflows, data, tools, and customer moments where intelligence could create leverage, then build the technology and adoption path that makes it useful in daily work.",
      beliefs: [
        {
          title: "AI first. Technology wide.",
          description:
            "NOUS leads with AI, but we build whatever the transformation needs: agents, automations, apps, integrations, data flows, websites, internal tools, and the infrastructure around them.",
        },
        {
          title: "Deployment over theater.",
          description:
            "AI creates value only when it changes real work. We care about prototypes, but we care more about useful systems that teams can trust, adopt, and improve.",
        },
        {
          title: "Independent by design.",
          description:
            "The intelligence layer is moving quickly. We stay model-aware, provider-aware, and use-case driven so organizations can choose what actually fits.",
        },
      ],
      capabilities: [
        "Understand the organization, workflows, and constraints.",
        "Find the highest-leverage places for AI to improve the work.",
        "Design the solution, operating model, and adoption path.",
        "Build the agents, automations, products, and integrations.",
        "Deploy, train, measure, and improve with the team.",
      ],
    };
---

<section class="mx-auto max-w-5xl px-4 pb-16 sm:pb-24" aria-labelledby="about-section-heading">
  <div class="space-y-6">
    <article class="relative isolate overflow-hidden rounded-[2rem] border border-outline/15 bg-white/[0.025] p-6 shadow-[0_24px_80px_rgba(0,0,0,0.18)] backdrop-blur sm:p-10">
      <div class="pointer-events-none absolute inset-x-8 top-0 h-px bg-gradient-to-r from-transparent via-outline/60 to-transparent" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0%,rgba(220,212,255,0.14),transparent_44%)]" aria-hidden="true"></div>

      <div class="relative z-10 grid gap-8 lg:grid-cols-[0.8fr_1.6fr] lg:items-center">
        <div class="flex justify-start">
          <img
            src={NousLogo.src}
            alt="NOUS logo"
            class="h-14 w-auto sm:h-16 lg:h-20"
            loading="lazy"
          />
        </div>

        <div>
          <p class="text-sm font-medium uppercase tracking-[0.18em] text-outline">{copy.eyebrow}</p>
          <h2 id="about-section-heading" class="mt-3 text-2xl font-medium leading-tight text-white sm:text-3xl">
            {copy.heading}
          </h2>
          <p class="mt-5 text-base leading-relaxed text-neutral-300 sm:text-justify sm:text-lg">
            {copy.description}
          </p>
        </div>
      </div>
    </article>

    <div class="grid gap-6 md:grid-cols-3">
      {copy.beliefs.map((belief) => (
        <article class="rounded-[2rem] border border-outline/15 bg-white/[0.022] p-6 shadow-[0_18px_64px_rgba(0,0,0,0.16)] backdrop-blur">
          <h3 class="text-xl font-medium leading-tight text-outline">
            {belief.title}
          </h3>
          <p class="mt-4 text-sm leading-relaxed text-neutral-300 md:text-justify">
            {belief.description}
          </p>
        </article>
      ))}
    </div>

    <article class="grid gap-8 rounded-[2rem] border border-outline/15 bg-white/[0.025] p-6 shadow-[0_24px_80px_rgba(0,0,0,0.16)] backdrop-blur sm:p-10 lg:grid-cols-[1fr_1.15fr] lg:items-center">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-outline">{copy.whatWeDo}</p>
        <h2 class="mt-3 text-2xl font-medium leading-tight text-white sm:text-3xl">
          {copy.operatingTitle}
        </h2>
        <p class="mt-5 text-base leading-relaxed text-neutral-300">
          {copy.operatingDescription}
        </p>
      </div>

      <ol class="space-y-3">
        {copy.capabilities.map((item, index) => (
          <li class="flex gap-4 rounded-full border border-white/10 bg-white/[0.03] px-4 py-3 text-sm leading-relaxed text-neutral-300">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-outline/25 bg-outline/10 text-xs font-medium text-outline">
              {String(index + 1).padStart(2, '0')}
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ol>
    </article>
  </div>
</section>
