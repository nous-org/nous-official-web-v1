---
import ButtonVariant from '@/components/ui/Buttons/ButtonVariant.astro';
import NousLogo from '@/assets/NousLogo.svg';
import HeroNousLogo from '@/components/ui/HeroNousLogo.astro';

interface HeroButton {
    text?: string;
    variant?: 'primary' | 'secondary' | 'primaryPurple' | 'secondaryTurquoise';
    href?: string;
    target?: '_blank' | '_self' | '_parent' | '_top';
    ariaLabel?: string;
}

interface Props {
    buttons?: HeroButton[];
    img?: string;
    title?: string;
    subtitle?: string;
    titleClassName?: string;
    subtitleClassName?: string;
    imgClassName?: string;
    isMainHero?: boolean;
    className?: string;
}

const {
    buttons = [
        {
            text: 'Find your AI opportunity',
            variant: 'primary',
            href: '/contact',
            target: '_self',
            ariaLabel: 'Find your AI opportunity'
        },
        {
            text: 'Explore what we do',
            variant: 'primaryPurple',
            href: '/contact',
            target: '_self',
            ariaLabel: 'Explore what NOUS does'
        }
    ],
    img = NousLogo,
    title = '',
    subtitle = '',
    titleClassName = '',
    subtitleClassName = '',
    imgClassName = '',
    isMainHero = false,
    className = ''
} = Astro.props;


const HeadingTag = isMainHero ? 'h1' : 'h2';
const imgSrc = typeof img === 'string' ? img : img.src;
---


<section
    class={`relative z-10 pt-44 md:pt-48 mb-64 px-4 sm:px-6 lg:px-8 ${className} animate-blurred-fade-in`}
    aria-labelledby="hero-cta-heading"
    role="banner"

>
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col items-center text-center gap-10 md:gap-12">

            <figure class="flex-shrink-0">
                {isMainHero ? (
                    <HeroNousLogo
                        className={`w-auto h-16 sm:h-20 md:h-32 lg:h-40 xl:h-52 object-contain ${imgClassName}`}
                    />
                ) : (
                    <img
                        src={imgSrc}
                        alt="NOUS AI deployment logo"
                        class={`w-auto h-16 sm:h-20 md:h-32 lg:h-40 xl:h-52 object-contain ${imgClassName}`}
                        transition:name="hero-image"
                        loading="eager"
                        decoding="async"
                    />
                )}
            </figure>

            <div class="flex flex-col items-center gap-10 md:gap-12">
                <HeadingTag
                    id="hero-cta-heading"
                    class={titleClassName || 'text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-bold font-archivo-black text-white leading-tight tracking-tight'}
                >
                    <slot name="title">{title}</slot>
                </HeadingTag>

                {subtitle && (
                    <p class={subtitleClassName || 'text-base sm:text-lg md:text-xl lg:text-2xl text-neutral-400 leading-relaxed max-w-2xl mx-auto'}>
                        {subtitle}
                    </p>
                )}
            </div>

            {buttons.length > 0 && (
                <nav aria-label="Hero call-to-action buttons">
                    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center items-center">
                        {buttons.map((button) => (
                            <ButtonVariant
                                text={button.text}
                                variant={button.variant}
                                href={button.href}
                                target={button.target}
                                ariaLabel={button.ariaLabel}
                            />
                        ))}
                    </div>
                </nav>
            )}
        </div>
    </div>
</section>
