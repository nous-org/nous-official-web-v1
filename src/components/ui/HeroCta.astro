---
import ButtonVariant from '@/components/ui/Buttons/ButtonVariant.astro';
import NousLogo from '@/assets/NousLogo.png';

interface HeroButton {
    text?: string;
    variant?: 'primary' | 'secondary' | 'primaryPurple' | 'secondaryTurquoise';
    href?: string;
    target?: '_blank' | '_self' | '_parent' | '_top';
    ariaLabel?: string;
}

interface Props {
    buttons?: HeroButton[];
    img?: string;
    title?: string;
    subtitle?: string;
    titleClassName?: string;
    subtitleClassName?: string;
    imgClassName?: string;
    isMainHero?: boolean;
    className?: string;
}

const {
    buttons = [
        {
            text: 'Contact',
            variant: 'secondary',
            href: '/contact',
            target: '_self',
            ariaLabel: 'Contact us for consultation'
        },
        {
            text: 'Request a demo',
            variant: 'primary',
            href: '/contact',
            target: '_self',
            ariaLabel: 'Request a product demonstration'
        }
    ],
    img = NousLogo,
    title = '',
    subtitle = '',
    titleClassName = '',
    subtitleClassName = '',
    imgClassName = '',
    isMainHero = false,
    className = ''
} = Astro.props;

// Determine heading level based on context
const HeadingTag = isMainHero ? 'h1' : 'h2';
const imgSrc = typeof img === 'string' ? img : img.src;
---

<!-- Hero Call-to-Action Section -->
<section 
    class={`relative z-10 pt-40 mb-72 px-4 sm:px-6 lg:px-8 ${className} animate-blurred-fade-in`}
    aria-labelledby="hero-cta-heading"
    role="banner"

>
    <div class="max-w-5xl mx-auto">
        <div class="flex flex-col items-center text-center space-y-6 sm:space-y-8 md:space-y-12">
          
            <figure class="flex-shrink-0">
                <img 
                    src={imgSrc}
                    alt="Nous Technologies - AI & Automation Solutions Logo"
                    class={`w-auto h-16 sm:h-20 md:h-32 lg:h-40 xl:h-52 object-contain ${imgClassName}`}
                    transition:name="hero-image"
                    loading="eager"
                    decoding="async"
                />
            </figure>
            
            <div class="space-y-4">
                <HeadingTag 
                    id="hero-cta-heading"
                    class={titleClassName || 'text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-bold font-archivo-black text-white leading-tight tracking-tight'}
                >
                    <slot name="title">{title}</slot>
                </HeadingTag>
                
                {subtitle && (
                    <p class={subtitleClassName || 'text-base sm:text-lg md:text-xl lg:text-2xl text-neutral-400 leading-relaxed max-w-2xl mx-auto'}>
                        {subtitle}
                    </p>
                )}
            </div>
            
            {buttons.length > 0 && (
                <nav aria-label="Hero call-to-action buttons">
                    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center items-center">
                        {buttons.map((button) => (
                            <ButtonVariant
                                text={button.text}
                                variant={button.variant}
                                href={button.href}
                                target={button.target}
                                ariaLabel={button.ariaLabel}
                            />
                        ))}
                    </div>
                </nav>
            )}
        </div>
    </div>
</section>
