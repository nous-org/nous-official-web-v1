---
import { DEFAULT_FOUNDERS } from '@/types/founderCards';
import { sanitizeHtml } from '@/lib/security';

interface Props {
    founders?: typeof DEFAULT_FOUNDERS;
    className?: string;
}

const { founders = DEFAULT_FOUNDERS, className = "" } = Astro.props;

function getInitials(name: string): string {
    return name
        .split(/\s+/)
        .filter(Boolean)
        .slice(0, 2)
        .map((part) => part.charAt(0))
        .join('')
        .toUpperCase();
}

const activeSocialLinks = (founder: typeof DEFAULT_FOUNDERS[number]) =>
    founder.socialLinks.filter((link) => link.url);
---

<!-- Founders Grid Container -->
<div class={`grid grid-cols-1 gap-6 pt-8 md:grid-cols-2 sm:pt-10 ${className} appear-left`}>
    {founders.length > 0 ? (
        founders.map((founder) => (
            <!-- Individual Founder Card -->
            <article
                class="relative flex min-h-full flex-col gap-5 overflow-hidden rounded-[2rem] border border-outline/15 bg-white/[0.025] p-5 shadow-[0_18px_64px_rgba(0,0,0,0.16)] backdrop-blur transition-colors duration-300 hover:border-outline/35 sm:p-6"
                aria-labelledby={`founder-${founder.name.replace(/\s+/g, '-').toLowerCase()}`}
            >
                <div class="pointer-events-none absolute inset-x-6 top-0 h-px bg-gradient-to-r from-transparent via-outline/35 to-transparent" aria-hidden="true"></div>

                <header class="flex items-center gap-4">
                    <div class="shrink-0">
                        {founder.image ? (
                            <div class="h-16 w-16 overflow-hidden rounded-full border border-outline/25 bg-outline/10 sm:h-20 sm:w-20">
                                <img
                                    src={founder.image}
                                    alt={`${founder.name}, ${founder.position} at NOUS`}
                                    class={`h-full w-full object-cover ${founder.imageClassName || "object-center"}`}
                                    loading="lazy"
                                />
                            </div>
                        ) : (
                            <div
                                aria-hidden="true"
                                class="flex h-16 w-16 items-center justify-center rounded-full border border-outline/25 bg-outline/10 text-lg font-medium text-outline sm:h-20 sm:w-20"
                            >
                                {getInitials(founder.name)}
                            </div>
                        )}
                    </div>
                    <div>
                        <h3
                            id={`founder-${founder.name.replace(/\s+/g, '-').toLowerCase()}`}
                            class="text-lg font-medium leading-tight text-white"
                        >
                            {founder.name}
                        </h3>
                        <p class="mt-1 text-xs font-medium leading-snug text-outline sm:text-[0.8125rem]">
                            {founder.position}
                        </p>
                    </div>
                </header>

                <div class="flex-1">
                    <p class="text-sm leading-relaxed text-neutral-300 md:text-justify" set:html={sanitizeHtml(founder.description)} />
                </div>

                {activeSocialLinks(founder).length > 0 && (
                    <nav aria-label={`${founder.name} social media links`}>
                        <div class="flex gap-3">
                            {activeSocialLinks(founder).map((link) => (
                                <a
                                    href={link.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="rounded-full border border-white/10 bg-white/[0.03] p-2 text-neutral-400 transition-all duration-300 hover:border-outline/40 hover:bg-outline/10 hover:text-outline"
                                    aria-label={`Visit ${founder.name} on ${link.name}`}
                                >
                                    <img
                                        src={link.icon}
                                        alt={`${link.name} icon`}
                                        class="h-4 w-4"
                                        loading="lazy"
                                    />
                                </a>
                            ))}
                        </div>
                    </nav>
                )}
            </article>
        ))
    ) : (
        <!-- Empty State -->
        <div class="col-span-full text-center py-12">
            <p class="text-neutral-400 text-lg">
                No team information available.
            </p>
        </div>
    )}
</div>
