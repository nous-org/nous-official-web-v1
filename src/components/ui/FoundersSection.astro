---
import FoundersCard from "@/components/ui/FoundersCard.astro";
---

<section class="mx-auto max-w-5xl px-4 pb-16 sm:pb-24" aria-labelledby="founders-heading">
    <div class="max-w-5xl appear-subtle">
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-outline">The team</p>
        <h2 id="founders-heading" class="mt-3 text-2xl font-medium leading-tight text-white sm:text-3xl">
            Built by operators who stay close to strategy, systems, and experience.
        </h2>
        <p class="mt-5 text-base leading-relaxed text-neutral-300 sm:text-lg">
            NOUS brings together business, engineering, product, growth, and marketing judgment. The work is hands-on by design: we stay close enough to understand the organization, make the hard decisions, and turn the AI opportunity into something people can actually use.
        </p>
    </div>
    <div>
        <FoundersCard />
    </div>
</section>
