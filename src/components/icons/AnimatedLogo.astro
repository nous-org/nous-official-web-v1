---
interface Props {
    width?: string | number;
    height?: string | number;
    className?: string;
    animationDuration?: string;
    ariaLabel?: string;
}

const { 
    width = "99", 
    height = "99", 
    className = "",
    animationDuration = "4s",
    ariaLabel = "Nous Technologies animated logo"
} = Astro.props;

// Generate unique ID for gradient to avoid conflicts
const gradientId = `nous-logo-gradient-${Math.random().toString(36).substr(2, 9)}`;
---

<svg 
    width={width} 
    height={height} 
    viewBox="0 0 99 99" 
    fill="none"
    class={`nous-animated-logo ${className}`}
    role="img"
    aria-label={ariaLabel}
>
    <!-- Outer ring path -->
    <path 
        d="M49.5 0C76.838 6.68613e-05 99 22.162 99 49.5C99 76.838 76.838 98.9999 49.5 99C22.1619 99 2.0619e-05 76.8381 0 49.5C0 22.1619 22.1619 0 49.5 0ZM49.3936 8.69238C26.7973 8.69252 8.47949 27.0111 8.47949 49.6074C8.47968 72.2036 26.7974 90.5213 49.3936 90.5215C71.9899 90.5215 90.3084 72.2037 90.3086 49.6074C90.3086 27.011 71.99 8.69238 49.3936 8.69238Z" 
        fill={`url(#${gradientId})`}
    />
    
    <!-- Animated eye pupil -->
    <circle 
        class="nous-eye-pupil" 
        cx="49.4995" 
        cy="49.499" 
        r="6.042" 
        fill={`url(#${gradientId})`}
        style={`animation-duration: ${animationDuration}`}
    />
    
    <!-- Gradient definition -->
    <defs>
        <linearGradient 
            id={gradientId} 
            x1="49.5" 
            y1="0" 
            x2="49.5" 
            y2="99" 
            gradientUnits="userSpaceOnUse"
        >
            <stop stop-color="#C9B6FF"/>
            <stop offset="1" stop-color="#FFC3E6"/>
        </linearGradient>
    </defs>
</svg>

<style>
    .nous-animated-logo {
        /* Responsive sizing */
        width: 100%;
        height: auto;
        max-width: 99px;
        
        /* Smooth transitions */
        transition: transform 0.3s ease;
    }
    
    .nous-animated-logo:hover {
        transform: scale(1.05);
    }
    
    .nous-eye-pupil {
        animation: nousEyeBlink 4s infinite ease-in-out;
        transform-origin: 49.5px 49.5px;
        
        /* Respect user's motion preferences */
        @media (prefers-reduced-motion: reduce) {
            animation: none;
        }
    }
    
    @keyframes nousEyeBlink {
        0%, 90%, 100% { 
            transform: scaleY(1); 
            opacity: 1; 
        }
        95% { 
            transform: scaleY(0.1); 
            opacity: 0.3; 
        }
    }
    
    /* Responsive sizing classes */
    @media (max-width: 640px) {
        .nous-animated-logo {
            max-width: 60px;
        }
    }
    
    @media (min-width: 641px) and (max-width: 1024px) {
        .nous-animated-logo {
            max-width: 80px;
        }
    }
    
    @media (min-width: 1025px) {
        .nous-animated-logo {
            max-width: 99px;
        }
    }
</style>