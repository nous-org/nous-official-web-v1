---
import ColorDivider from "@/components/ui/ColorDivider.astro"
import ButtonVariant from "../ui/Buttons/ButtonVariant.astro"
---

<footer class="relative bg-gradient-to-t from-primary-black to-primary-blue">

    <ColorDivider colorDivider="primary-purple"/>

    <div class="container mx-auto mt-10 max-w-7xl px-4">
        <!-- Main Footer Content -->
        <div class="grid w-full grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-[1fr_1fr_1.1fr_0.9fr_max-content] lg:gap-12 xl:gap-14">

            <!-- Company Section -->
            <section class="col-span-1 flex flex-col gap-4 sm:col-span-2 lg:col-span-1">
                <header class="flex flex-col gap-4">
                    <h2 class="text-2xl font-medium tracking-normal text-white">NOUS</h2>
                    <p class="text-sm leading-relaxed text-neutral-300">Building a more intelligent world.</p>
                </header>
                <div class="flex w-full flex-col gap-4">
                    <ButtonVariant
                        text="Talk to NOUS"
                        variant="primary"
                        href="/contact"
                        rounded="full"
                        strokeColor="#060114"
                        justify="center"
                        className="!w-full"
                    />
                    <ButtonVariant
                        text="Explore services"
                        variant="primaryPurple"
                        href="/services"
                        rounded="full"
                        strokeColor="#DCD4FF"
                        justify="center"
                        className="!w-full"
                    />
                </div>
            </section>

            <!-- Contact Section -->
            <section class="col-span-1 flex flex-col gap-4 lg:justify-self-end">
                <header>
                    <h3 class="text-xl sm:text-2xl font-medium text-outline">Contact</h3>
                </header>
                <address class="flex flex-col gap-4 not-italic">
                    <ul class="space-y-4 text-neutral-300">
                        <li>
                            <a
                              href="mailto:hello@nous.cr"
                              class="hover:text-hover transition-colors duration-200 email-link"
                              data-email="hello@nous.cr"
                            >
                                hello@nous.cr
                            </a>
                        </li>
                    </ul>
                    <p class="text-xs leading-relaxed text-neutral-300">Hermes will start the conversation, gather initial context, and route it to the right person at NOUS.</p>
                    <div>
                        <a href="https://wa.me/50661865634" target="_blank" rel="noopener noreferrer" class="text-outline hover:text-hover transition-colors duration-200 font-medium">
                            (+506) 6186-5634
                        </a>
                    </div>
                </address>
            </section>

            <!-- Newsletter Section -->
            <section class="col-span-1 flex flex-col gap-4">
                <header>
                    <h3 class="text-xl sm:text-2xl font-medium text-outline">Newsletter</h3>
                </header>

                <!-- Newsletter Form -->
                <form id="footer-newsletter-form" method="POST" action="/api/subscribe" class="flex flex-col gap-4">
                    <div class="flex flex-col gap-4">
                        <label for="footer-email-address" class="sr-only">E-mail address</label>
                        <input
                            id="footer-email-address"
                            type="email"
                            name="email"
                            placeholder="roberto@nous.cr"
                            required
                            class="min-h-11 w-full rounded-full border border-neutral-700 bg-white/[0.03] px-5 py-2.5 text-sm text-neutral-200 placeholder-neutral-500 backdrop-blur transition-colors hover:border-outline/70 focus:border-outline focus:outline-none focus:ring-2 focus:ring-outline/20"
                        />
                        <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
                        <button
                            type="submit"
                            class="min-h-11 w-full rounded-full border border-transparent bg-outline px-5 py-2.5 text-sm font-medium text-primary-black transition-all duration-200 hover:bg-hover hover:shadow-sm hover:shadow-outline/20 focus:outline-none focus:ring-2 focus:ring-outline/50 disabled:cursor-not-allowed disabled:opacity-50 cursor-pointer"
                        >
                            Subscribe
                        </button>
                    </div>

                    <!-- Status Messages -->
                    <div id="footer-email-error" class="hidden" role="alert" aria-live="polite">
                        <div class="flex items-center gap-2 text-xs text-red-400">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span id="footer-error-message">Please enter a valid e-mail address</span>
                        </div>
                    </div>

                    <div id="footer-success-message" class="hidden" role="alert" aria-live="polite">
                        <div class="flex items-center gap-2 text-xs text-green-400">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            <span id="footer-success-text">Successfully subscribed!</span>
                        </div>
                    </div>

                    <div id="footer-loading-message" class="hidden" role="status" aria-live="polite">
                        <div class="flex items-center gap-2 text-xs text-outline">
                            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="m4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span>Subscribing...</span>
                        </div>
                    </div>
                </form>

                <div class="space-y-3">
                    <p class="text-neutral-400 text-xs leading-relaxed">Field notes on the era of abundant intelligence: how intelligence on tap will reshape decisions, tools, infrastructure, and the organizations ready to use it.</p>
                    <p class="text-neutral-400 text-xs leading-relaxed">By subscribing you agree to our <a href="/privacy-policy" class="text-neutral-400 text-xs leading-relaxed hover:text-outline transition-colors">Privacy Policy</a>.</p>
                </div>
            </section>

            <!-- Products Section -->
            <section class="col-span-1 flex flex-col gap-4">
                <header>
                    <h3 class="text-xl sm:text-2xl font-medium text-outline">Services</h3>
                </header>
                <nav>
                    <ul class="space-y-4 text-neutral-300">
                        <li>
                            <a href="/services#services" class="hover:text-outline transition-colors duration-200 text-sm">
                                AI Transformation Strategy
                            </a>
                        </li>
                        <li>
                            <a href="/services#services" class="hover:text-outline transition-colors duration-200 text-sm">
                                Intelligence Deployment
                            </a>
                        </li>
                        <li>
                            <a href="/services#services" class="hover:text-outline transition-colors duration-200 text-sm">
                                AI-Ready Systems
                            </a>
                        </li>
                    </ul>
                </nav>
            </section>

            <!-- Company Navigation Section -->
            <section class="col-span-1 flex flex-col gap-4">
                <header>
                    <h3 class="text-xl sm:text-2xl font-medium text-outline">Company</h3>
                </header>
                <nav>
                    <ul class="space-y-4 text-neutral-300">
                        <li><a href="/" class="hover:text-outline transition-colors duration-200 text-sm">Home</a></li>
                        <li><a href="/services" class="hover:text-outline transition-colors duration-200 text-sm">Services</a></li>
                        <li><a href="/portfolio" class="hover:text-outline transition-colors duration-200 text-sm">Portfolio</a></li>
                        <li><a href="/about" class="hover:text-outline transition-colors duration-200 text-sm">About</a></li>
                        <li><a href="/blog" class="hover:text-outline transition-colors duration-200 text-sm">Blog</a></li>
                        <li><a href="/contact" class="hover:text-outline transition-colors duration-200 text-sm">Talk to NOUS</a></li>
                    </ul>
                </nav>
            </section>
        </div>

        <!-- Footer Bottom -->
        <div class="border-t border-neutral-800 mt-12 pt-8">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pb-8">
                <p class="text-neutral-400 font-light text-sm">
                    NOUS 2026. All rights reserved.
                </p>
                <nav class="flex flex-col sm:flex-row gap-2 sm:gap-6">
                    <a href="/privacy-policy" class="text-neutral-400 hover:text-outline transition-colors duration-200 text-sm">
                        Privacy Policy
                    </a>
                    <a href="/terms-and-conditions" class="text-neutral-400 hover:text-outline transition-colors duration-200 text-sm">
                        Terms and Conditions
                    </a>

                </nav>
            </div>
        </div>
    </div>
</footer>

<script is:inline>
    function initializeEmails() {
        const emailLinks = document.querySelectorAll('.email-link');

        emailLinks.forEach(link => {
            const email = link.getAttribute('data-email');
            if (email) {
                link.href = `mailto:${email}`;

                if (link.textContent !== email) {
                    link.textContent = email;
                }
            }
        });
    }


    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeEmails);
    } else {
        initializeEmails();
    }


    document.addEventListener('astro:page-load', initializeEmails);

    // Footer newsletter form handler.
    function initializeFooterNewsletter() {
        const form = document.getElementById('footer-newsletter-form');
        if (!form) return;

        // Avoid duplicate initialization across Astro page transitions.
        if (form.dataset.initialized === 'true') return;
        form.dataset.initialized = 'true';

        const emailInput = document.getElementById('footer-email-address');
        const submitButton = form.querySelector('button[type="submit"]');
        const errorBox = document.getElementById('footer-email-error');
        const successBox = document.getElementById('footer-success-message');
        const loadingBox = document.getElementById('footer-loading-message');
        const errorText = document.getElementById('footer-error-message');
        const successText = document.getElementById('footer-success-text');

        let busy = false;

        function hideAll() {
            errorBox?.classList.add('hidden');
            successBox?.classList.add('hidden');
            loadingBox?.classList.add('hidden');
        }

        function showError(msg) {
            hideAll();
            if (errorText) errorText.textContent = msg;
            errorBox?.classList.remove('hidden');
        }

        function showSuccess(msg) {
            hideAll();
            if (successText) successText.textContent = msg;
            successBox?.classList.remove('hidden');
        }

        function showLoading() {
            hideAll();
            loadingBox?.classList.remove('hidden');
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            if (busy) {
                return;
            }
            busy = true;

            const email = emailInput?.value?.trim();
            if (!email) {
                showError('Please enter your e-mail address');
                busy = false;
                return;
            }

            showLoading();
            if (submitButton) submitButton.disabled = true;

            try {
                const formData = new FormData();
                formData.append('email', email);
                formData.append('website', form.querySelector('[name="website"]')?.value || '');

                const response = await fetch('/api/subscribe', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (response.ok) {
                    showSuccess(data.message || 'Successfully subscribed!');
                    form.reset();
                } else {
                    showError(data.message || 'Something went wrong. Please try again.');
                }
            } catch (error) {
                console.error('Newsletter submission error');
                showError('Network error. Please check your connection and try again.');
            } finally {
                busy = false;
                if (submitButton) submitButton.disabled = false;
            }
        });
    }

    // Initialize footer newsletter on page load
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeFooterNewsletter);
    } else {
        initializeFooterNewsletter();
    }

    document.addEventListener('astro:page-load', initializeFooterNewsletter);
</script>
