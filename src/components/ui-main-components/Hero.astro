---
import HeroCta from '@/components/ui/HeroCta.astro';

---

<HeroCta 
buttons={[{
    text: 'Contact',
    variant: 'secondary',
    href: '/contact',
    target: '_self',
    ariaLabel: 'Button'
}, {
        text: 'Products',
        variant: 'secondaryTurquoise',
        href: '/products',
        target: '_self',
        ariaLabel: 'Button'
    }]}
    titleClassName='lg:text-6xl max-w-6xl md:text-5xl text-2xl font-archivo-black mb-10 text-neutral-200 text-center'
    subtitle='Your brand, your identity, and your processes, all running automatically'
    subtitleClassName='lg:text-xl md:text-lg text-sm text-center text-neutral-400'
    >
    <span slot="title">
        Intelligent <span class="bg-gradient-to-r from-primary-purple via-primary-turquoise to-primary-turquoise bg-clip-text text-transparent">automation with AI</span>, web development, and tailored products for your business
    </span>
</HeroCta>


