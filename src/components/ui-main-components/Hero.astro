---
import HeroCta from '@/components/ui/HeroCta.astro';

---

<HeroCta 
buttons={[{
    text: 'Find your AI opportunity',
    variant: 'primary',
    href: '/contact',
    target: '_self',
    ariaLabel: 'Find your AI opportunity'
}, {
        text: 'Explore what we do',
        variant: 'primaryPurple',
        href: '/services',
        target: '_self',
        ariaLabel: 'Explore what NOUS does'
    }]}
    isMainHero={true}
    titleClassName='text-3xl sm:text-4xl md:text-5xl xl:text-6xl 2xl:text-7xl max-w-7xl font-medium leading-[1.05] tracking-normal text-neutral-100 text-center'
    subtitle='We help organizations turn AI into real advantage: strategy, agents, automation, training, and the systems to deploy intelligence at work.'
    subtitleClassName='lg:text-xl md:text-lg text-sm text-center text-neutral-300/90 leading-relaxed max-w-4xl mx-auto'
    >
    <span slot="title">
          <span class="block md:whitespace-nowrap bg-gradient-to-r from-gradient-start via-gradient-middle to-gradient-end bg-clip-text text-transparent">AI is the next transformation.</span>
          <span class="block md:whitespace-nowrap bg-gradient-to-r from-gradient-start via-gradient-middle to-gradient-end bg-clip-text text-transparent">NOUS helps you lead it.</span>
    </span>
</HeroCta>
