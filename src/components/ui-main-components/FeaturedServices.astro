---
import { CardDemo } from "@/components/react/InfoCard.tsx";
import InfoText from "@/components/ui/InfoText.astro";
//import ButtonVariant from "@/components/ui/Buttons/ButtonVariant.astro";
import { DEFAULT_INFO_TEXT_2 } from "@/types/InfoText";
---

<section class="max-w-7xl mx-auto px-4 container z-10 pt-64 pb-52">
    <article class="grid md:grid-cols-2 grid-cols-1 gap-4 md:gap-4">
        <div class="flex flex-col md:mx-0 appear-left"
        
        >
            <CardDemo client:only="react" />
            
        </div>

        <div class="mt-16 sm:mt-0 md:mt-0">
            <InfoText />
        </div>
    </article>

    <article class="flex flex-col md:grid md:grid-cols-2 gap-4 md:gap-8 mt-40">
        <div class="order-2 md:order-1 mt-16 md:mt-0" >
            <InfoText
                infoText={DEFAULT_INFO_TEXT_2}
                colorDivider="primary-purple"
            />
        </div>

        <div
            class="flex flex-col md:mx-0 order-1 md:order-2 lg:justify-self-end appear"
            >
            <CardDemo
                client:only="react"
                iconSet="secondary"
                borderColor="border-outline"
                title="Modern web development."
                description="Your website shouldn’t just exist—it should work for you: tell your story, earn trust, and turn attention into growth."
            />
          
        </div>
    </article>
</section>
