---
import { CardDemo } from "@/components/react/InfoCard.tsx";
import InfoText from "@/components/ui/InfoText.astro";
//import ButtonVariant from "@/components/ui/Buttons/ButtonVariant.astro";
import { DEFAULT_INFO_TEXT_2 } from "@/types/InfoText";
---

<section class="max-w-7xl mx-auto px-4 container z-10 pt-64 pb-52">
    <article class="grid grid-cols-1 items-center gap-4 md:grid-cols-2 md:gap-8">
        <div class="flex flex-col md:mx-0 md:self-center appear-left"
        
        >
            <CardDemo client:only="react" justifyDescription={true} />
            
        </div>

        <div class="mt-16 sm:mt-0 md:mt-0 md:self-center">
            <InfoText justifyDescription={true} descriptionMaxWidthClass="max-w-xl" />
        </div>
    </article>

    <article class="flex flex-col md:grid md:grid-cols-2 gap-4 md:gap-8 mt-40 md:items-center">
        <div class="order-2 md:order-1 mt-16 md:mt-0 md:self-center" >
            <InfoText
                infoText={DEFAULT_INFO_TEXT_2}
                colorDivider="primary-purple"
                justifyDescription={true}
                descriptionMaxWidthClass="max-w-xl"
            />
        </div>

        <div
            class="flex flex-col md:mx-0 md:self-center order-1 md:order-2 lg:justify-self-end appear"
            >
            <CardDemo
                client:only="react"
                iconSet="secondary"
                borderColor="border-outline"
                title="AI-Ready Systems for the whole organization."
                description="AI does not transform a company by floating above it. It needs software, data, integrations, interfaces, and operations designed so intelligence can move through the business."
                justifyDescription={true}
            />
          
        </div>
    </article>
</section>
