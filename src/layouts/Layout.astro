---
import Header from '@/components/ui-main-components/Header.astro';
import Footer from '@/components/ui-main-components/Footer.astro';
import {AuroraBackground} from '@/components/react/AuroraBackground.tsx';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<meta name="generator" content={Astro.generator} />
		<title>Nous Technologies: AI & Automation</title>
	</head>
	<body class="bg-[#060114] relative">
		<AuroraBackground />
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		
	</body>
</html>

<style>
	@font-face {
		font-family: 'TikTokSans';
		src: url('/fonts/TikTokSans.woff2') format('woff2');
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}
	@font-face{
		font-family: 'ArchivoBlack-Regular';
		src: url('/fonts/ArchivoBlack-Regular.woff2') format('woff2');
		font-weight: normal;
		font-style: normal;
		font-display: swap;
		}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: 'TikTokSans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif, 'ArchivoBlack-Regular';
		color-scheme: dark;
	}

	* {
		font-family: 'TikTokSans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif, 'ArchivoBlack-Regular';
		
	}
	
</style>

<script>
	import '../styles/global.css'
</script>