---
import Header from '@/components/ui-main-components/Header.astro';
import Footer from '@/components/ui-main-components/Footer.astro';
import { AuroraBackground } from '@/components/react/AuroraBackground.tsx';
import SEOBase from '@/components/seo/SEO.astro';
import OrganizationSchema from '@/components/seo/OrganizationSchema.astro';
import '@/styles/global.css'

interface Props {
  title?: string;
  showAurora?: boolean;
  useContainer?: boolean;
  backgroundType?: 'aurora' | 'primary' | 'custom';
  customBgClass?: string;
  overflowType?: 'hidden' | 'visible';
  paddingType?: 'normal' | 'zero';
  
  // SEO Props (expandidos)
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  type?: 'website' | 'article' | 'product' | 'profile';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
  noindex?: boolean;
  nofollow?: boolean;
  
  // Schema Props
  customSchema?: any;
  includeOrganizationSchema?: boolean;
}

const { 
  title = 'NOUS / AI Deployment Company',
  showAurora = true,
  useContainer = false,
  backgroundType = 'aurora',
  customBgClass = '',
  overflowType = 'visible',
  paddingType = 'normal',
  
  // SEO
  description = 'NOUS helps organizations in Costa Rica and Latin America build, deploy, and adopt AI systems that turn intelligence into practical work.',
  canonical = Astro.url?.pathname,
  ogImage = '/images/og-default.jpg',
  ogImageAlt = 'NOUS helps organizations build and deploy practical AI systems',
  type = 'website',
  publishedTime,
  modifiedTime,
  author = 'NOUS',
  tags = [],
  noindex = false,
  nofollow = false,
  
  // Schema
  customSchema,
  includeOrganizationSchema = true,
} = Astro.props;

const getBgClass = () => {
  switch (backgroundType) {
    case 'primary':
      return 'bg-primary-blue';
    case 'custom':
      return customBgClass;
    case 'aurora':
    default:
      return 'bg-[#060114]';
  }
};

const getPaddingClass = () => {
  switch (paddingType) {
    case 'normal':
      return 'px-4';
    case 'zero':
      return 'px-0';
    default:
      return 'px-4';
  }
};

const getOverflowClass = () => {
  switch (overflowType) {
    case 'hidden':
      return 'overflow-x-hidden';
    default:
      return 'overflow-visible';
  }
};

const mainClasses = useContainer 
  ? 'max-w-7xl container mx-auto' 
  : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="NOUS" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Component -->
    <SEOBase
      title={title}
      description={description}
      canonical={canonical}
      image={ogImage}
      imageAlt={ogImageAlt}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      tags={tags}
      schema={customSchema}
      noindex={noindex}
      nofollow={nofollow}
    />
    
    <!-- Organization Schema (solo en páginas principales) -->
    {includeOrganizationSchema && <OrganizationSchema />}
    
    <!-- Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
  </head>

  <body class={`${getBgClass()} relative ${getOverflowClass()}`}>
    {showAurora && <AuroraBackground client:load/>}
  
    <a href="#main-content" class="sr-only fixed left-4 top-4 z-[100] rounded-full bg-outline px-4 py-2 text-sm font-medium text-primary-black focus:not-sr-only focus:outline-none focus:ring-2 focus:ring-outline/60 focus:ring-offset-2 focus:ring-offset-primary-black">
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class={`${getPaddingClass()} ${mainClasses}`}>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    color-scheme: dark;
  }

  * {
    font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  }
</style>
